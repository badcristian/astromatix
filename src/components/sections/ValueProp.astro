---
import FeatureCard from '../ui/FeatureCard.astro';
import Reveal from '../ui/Reveal.astro';
import copy from '../../i18n/home-copy.json';
import iconCentraliseren from '../../assets/icon-centraliseren.png';
import iconAutomatiseren2 from '../../assets/icon-automatiseren-2.png';
import iconAutomatiseren from '../../assets/icon-automatiseren.png';

// Measured @1440:
//   section   y=712 h=793, padding 80px 24px 0
//   h2        y=792 x=195 w=1050 h=105, Poppins 700 30px/52.5px, navy,
//             centred, margin-bottom 24
//   intro     y=921 w=1050 h=95, 18px/31.5px, navy, centred
//   card row  y=1060 w=1200 h=399, three s4 columns of 408 with 12px gutters
//   card      icon 29×29 at y=1107 (47px in), title y=1175 20px Poppins 700,
//             body 16px/22.4px — all centred
//
// Copy comes from home-copy.json, extracted mechanically by
// scripts/extract-copy.mjs rather than transcribed.

const { valueProp } = copy;
const icons = [iconCentraliseren, iconAutomatiseren2, iconAutomatiseren];
---

{/* 79px top, not 80: the original's section overlaps the feature band above it
    by 1px, and our sections are strictly sequential.
    46px bottom: the original has an empty 1200×46 spacer row between the cards
    and the CTA strip that follows. */}
<section class="px-6 pt-[79px] pb-[46px]">
  <div class="mx-auto max-w-[1200px]">
    <div class="mx-auto max-w-[1050px] text-center">
      <h2
        class="font-display text-[30px] leading-[52.5px] font-bold text-navy"
        set:html={valueProp.titleHtml}
      />
      <p class="mt-6 text-[18px] leading-[31.5px] text-navy">
        {valueProp.intro}
      </p>
    </div>

    {/* mb-12: the original's card row is 399 tall while its columns are 351,
        i.e. 48px of trailing space below the cards. */}
    <Reveal variant="zoom" duration={1000} class="mt-11 mb-12 flex flex-wrap justify-center -mx-3">
      {valueProp.cards.map((card, i) => (
        <div class="w-full px-3 md:w-1/2 lg:w-1/3">
          <FeatureCard icon={icons[i]} title={card.title} body={card.body} />
        </div>
      ))}
    </Reveal>
  </div>
</section>
