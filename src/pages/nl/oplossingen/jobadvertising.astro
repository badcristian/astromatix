---
import Base from '../../../layouts/Base.astro';
import ProductHero from '../../../components/sections/ProductHero.astro';
import FeatureBand from '../../../components/sections/FeatureBand.astro';
import FeatureCard from '../../../components/ui/FeatureCard.astro';
import Accordion from '../../../components/ui/Accordion.astro';
import CtaStrip from '../../../components/sections/CtaStrip.astro';
import ContactCta from '../../../components/sections/ContactCta.astro';
import Reveal from '../../../components/ui/Reveal.astro';
import QuickFeat from '../../../components/ui/QuickFeat.astro';
import FeatureShowcase from '../../../components/ui/FeatureShowcase.astro';
import Steps from '../../../components/ui/Steps.astro';
import { Image } from 'astro:assets';
import { resolveIcon } from '../../../lib/icons';
import page from '../../../i18n/pages/nl-oplossingen-jobadvertising.json';
import { bandFor, heroBand } from '../../../lib/bands';

// Section map measured on the original @1440 (page height 4890):
//   hero        y=85   h=552  navy, padding 100/24/0
//   props band  y=638  h=84   navy, four properties
//   card grid   y=722  h=970  five feature cards
//   cta strip   y=2398 h=150  navy
//   faq         y=2968 h=704  mist, four accordion items
//   contact     y=3672 h=834  form
//
// HEADINGS ARE LOOKED UP BY CONTENT, NOT INDEX.
//
// This file used to read page.headings[3], [10], [12], [13]. Those indices
// silently rot: the extractor gained a visibility filter (it was picking up a
// HIDDEN quickfeat module whose copy near-misses the visible featshow — "Data
// insights" vs the original's "Data inzicht"), the heading list shortened from
// 13 to 10, and every index below pointed at the wrong string or at undefined.
//
// A wrong index does not fail loudly; it renders someone else's sentence, or
// nothing. Looking headings up by their opening words means a miss is
// obvious and the intent is readable. See FINDINGS.md on hidden modules.

// The properties band needs icon keys; the original serves per-item images,
// which we map onto our own glyph set.
const bandIcons = ['download', 'expand', 'send', 'arrow'] as const;
const band = page.properties.map((p, i) => ({ icon: bandIcons[i], label: p.label }));


/** The page's own heading that starts with `prefix`, or null. */
const heading = (prefix: string) =>
  page.headings.find((h) => h.toLowerCase().startsWith(prefix.toLowerCase())) ?? null;

/** Same, but across all heading levels — some of these are h3/h4. */
const block = (prefix: string) =>
  page.blocks?.find((b: any) => b.heading?.toLowerCase().startsWith(prefix.toLowerCase())) ?? null;

const heroSubtitle = heading('De beste alles-in-een oplossing');
const cardsHeading = heading('Bereik altijd de juiste kandidaten');
// The intro paragraph under that heading (a rich_text widget on the original);
// it lives on the block's body and was simply never rendered.
const cardsIntro = block('Bereik altijd de juiste kandidaten')?.body?.[0] ?? null;
const stripHeading = block('Benieuwd hoe jij jouw job marketing')?.heading ?? null;
const stepsHeading = heading("Let's get your job done");
const faqHeading = heading('Veelgestelde vragen');
const ctaHeading = heading('Klaar om jouw vacatures');

const heroCta = page.buttons.find((b) => b.href?.includes('demo-aanvraag')) ?? null;
const stripCta = page.buttons.find((b) => b.href?.includes('demo-aanvragen')) ?? null;

// A 588px-wide dashboard illustration sits beside the FAQ on both product
// pages. It carries NO module class, so no module-based extractor could see it
// and it was simply absent — worth ~650px here and ~250px on jobboost. Found
// by contentImages, which anchors on the nearest preceding heading.
const faqImage = (() => {
  const hit = (page.contentImages ?? []).find(
    (i: any) => i.afterHeading?.startsWith('Veelgestelde vragen') && i.width > 300,
  );
  const resolved = resolveIcon(hit?.src);
  return resolved ? { ...hit, resolved } : null;
})();
---

<Base title={page.meta.title} description={page.meta.description ?? undefined}>
  {/* The original hard-breaks the h1 ("Job <br>Advertising") and serves a big
      right-anchored dashboard (background-size:contain, renders ~812x552). We
      match the break and enlarge the image to 720 wide. imageHeight tracks the
      asset's true 1000x680 ratio (1.47) — the old 588x317 squashed it. */}
  <ProductHero
    title={page.hero.title}
    titleHtml="Job <br>Advertising"
    subtitle={heroSubtitle}
    cta={heroCta ? { label: heroCta.label, href: heroCta.href } : null}
    image={resolveIcon(page.hero.background)}
    imageWidth={720}
    imageHeight={490}
    theme="light"
  />

  <FeatureBand items={band} chip={false} />

  <section class="px-6 pt-[70px] pb-[20px]">
    <div class="mx-auto max-w-[1200px]">
      <h2 class="mx-auto max-w-[1050px] text-center font-display text-[30px] leading-[52.5px] font-bold text-navy">
        {cardsHeading}
      </h2>
      {cardsIntro && (
        <p class="mx-auto mt-4 max-w-[1050px] text-center text-[18px] leading-[25.2px] text-navy">
          {cardsIntro}
        </p>
      )}

      <Reveal variant="zoom" duration={1000} class="mt-11 flex flex-wrap justify-center -mx-3">
        {page.featureCards.map((card, i) => (
          <div class="w-full px-3 md:w-1/2 lg:w-1/3">
            <FeatureCard icon={resolveIcon(card.icon)} title={card.title} body={card.body} />
          </div>
        ))}
      </Reveal>
    </div>
  </section>

  {/* Mist band (full width). The original sits this section on a
      `section-bg__custom--color` layer at #f5f5ff so the white featshow card
      floats on a tint — distinct from the plain-white cards section above. */}
  {page.featshow && (
    <section class="bg-mist px-6 py-[70px]">
      <FeatureShowcase items={page.featshow} />
    </section>
  )}

  {stripCta && stripHeading && <CtaStrip heading={stripHeading} cta={stripCta} />}

  {page.steps && (
    <section class="px-6 py-10">
      <h2 class="mb-10 text-center font-display text-[30px] leading-[33px] font-bold text-navy">
        {stepsHeading}
      </h2>
      <Steps steps={page.steps} />
    </section>
  )}

  {page.quickfeat && (
    <section class="bg-mist px-6 py-24">
      <div class="mx-auto max-w-[1138px]">
        <QuickFeat items={page.quickfeat} />
      </div>
    </section>
  )}

  {/* Image LEFT (588x317 at x=120), heading + accordion RIGHT — a two-column
      section on a WHITE background (not mist). The accordion is its own white
      card with the theme's soft navy shadow. */}
  <section class="bg-white px-6 py-[60px]">
    <div class="mx-auto flex max-w-[1200px] flex-col items-center gap-10 lg:flex-row lg:gap-20">
      {faqImage && (
        <Image
          src={faqImage.resolved}
          alt=""
          width={faqImage.width}
          height={faqImage.height}
          class="h-auto w-full rounded-3xl lg:w-[588px] lg:shrink-0"
        />
      )}
      <div class="lg:flex-1">
        {/* Default chrome: white card, 24px radius, the theme's shadow, 96px
            vertical padding — all measured on the original. "Veelgestelde
            vragen" sits INSIDE that card (see Accordion), as on the original. */}
        <Accordion items={page.accordion} heading={faqHeading} />
      </div>
    </div>
  </section>

  <ContactCta title={ctaHeading!} intro={null} band={bandFor(page, "Klaar om jouw")} />
</Base>
