---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from '../ui/Button.astro';
import Reveal from '../ui/Reveal.astro';

// Measured @1440. Both blocks share one structure, alternating sides:
//   section  padding 80px 24px 50px; block 1 on mist, block 2 on white
//   inner    1200 wide, centred
//   image    600 wide, 24px radius
//   text     520 wide, 80px gap from the image, VERTICALLY CENTRED against it
//            (44px offset in block 1, 71px in block 2 — both exact centring)
//   h2       Poppins 700 30px/52.5px navy
//   body     16px/28px navy, 24px below the heading
//   button   52px tall, 24px below the body
//
// Block 1: text left  @x=120, image right @x=720
// Block 2: image left @x=120, text right  @x=800

interface Props {
  title: string;
  body: string;
  image: ImageMetadata;
  cta: { label: string; href: string };
  /** Put the image on the left and the text on the right. */
  reverse?: boolean;
  /** Scroll-reveal direction: block 1 slides left, block 2 right. */
  reveal?: 'left' | 'right';
  background?: 'mist' | 'white';
  /**
   * Width at which the image and text stop being side-by-side.
   *
   * NOT a style preference — the original genuinely differs by page, because
   * these blocks come from two different theme modules (FINDINGS.md §3):
   *
   *   'lg'  homepage (module--img-txt). Stacks below 1140. Measured at 768:
   *         the image is 720px wide in a 720px row, i.e. already full width.
   *   'md'  platform (module--image + module--rtext). Stays two-column down to
   *         the theme's 767 breakpoint. Measured at 768: the image is 348px
   *         wide in a 768px viewport, i.e. still a half column.
   *
   * Setting this globally to 'md' fixed /nl/platform (+2509 -> +1295 at 768)
   * and broke the homepage by 832px in the other direction. Exactly the
   * per-component measurement FINDINGS.md §7 calls for.
   */
  stackUntil?: 'md' | 'lg';
  /**
   * Drop the image entirely below 768px.
   *
   * Not a judgement call — /nl/platform's theme sets `display: none` on the
   * image column's `.span12` wrapper below exactly 768 (verified at 479, 480,
   * 600, 767 vs 768). Four of its five images never render on mobile, which is
   * why that page gets SHORTER as it narrows (4242 -> 4019 -> 3556) where a
   * naive stack gets taller. Rendering them cost ~2000px at 390.
   */
  hideImageBelowMd?: boolean;
  /**
   * Feature list under the body copy.
   *
   * The homepage's Job Advertising and Jobboost blocks each carry a four-item
   * `.module--properties` list with inline-SVG ticks (y=2143 and y=2766). They
   * were not extracted and not rendered — eight icons and eight lines of copy
   * missing from the most important page on the site.
   */
  properties?: { label: string; iconSvg?: string | null }[];
}

const {
  title, body, image, cta,
  reverse = false, reveal = 'left', background = 'white',
  stackUntil = 'lg',
  hideImageBelowMd = false,
  properties = [],
} = Astro.props;
---

{/* pb is 138, not the section's own 50: the original follows each block's
    inner row with an empty 1200×88 spacer before the section's bottom
    padding. Same pattern as the 46px spacer under the value prop. */}
{/* Vertical padding is reduced BELOW md only. The 80/138 figures were
    measured at 1440, where the original follows each block with an empty
    1200x88 spacer; that spacer does not survive to mobile, so carrying 218px
    of padding down to 390 ran every block ~300px long. Restored from md up,
    because the homepage sits at +55 there and must not be disturbed. */}
<section
  class:list={[
    'px-[10px] pt-10 pb-12 md:px-6 md:pt-20 md:pb-[138px]',
    background === 'mist' && 'bg-mist',
  ]}
>
  <Reveal
    variant={reveal}
    duration={1000}
    class:list={[
      'mx-auto flex flex-col gap-10',
      // Platform's blocks measure 611/611 — a ~1242 content area, not 1200 —
      // so it gets a wider frame and a small gap; the homepage keeps 1200.
      stackUntil === 'md'
        ? ['max-w-[1242px] md:flex-row md:gap-5', reverse && 'md:flex-row-reverse']
        : ['max-w-[1200px] lg:flex-row lg:gap-20', reverse && 'lg:flex-row-reverse'],
    ]}
  >
    {/* Platform (stackUntil='md') is an EQUAL 50/50 split — measured 611/611
        on the original — where the homepage is a fixed 600 image beside a 520
        text column. Keeping the homepage's narrow text on platform read 520 vs
        611. */}
    <div class:list={[
      hideImageBelowMd && 'hidden md:block',
      stackUntil === 'md' ? 'md:w-1/2' : 'lg:w-[600px] lg:shrink-0',
    ]}>
      <Image
        src={image}
        alt=""
        width={600}
        densities={[1, 2]}
        class="w-full rounded-3xl"
      />
    </div>

    {/* top-px: centring an odd remainder (43.5px in block 1, 70.5 in block 2)
        rounds down here and up on the original. Nudged rather than pinned so
        it stays correct if the copy reflows. */}
    <div class:list={[
      'text-center lg:relative lg:top-px lg:self-center',
      stackUntil === 'md' ? 'md:w-1/2 md:self-center md:text-left' : 'lg:w-[520px] lg:text-left',
    ]}>
      <h2 class="font-display text-[30px] leading-[52.5px] font-bold text-navy">
        {title}
      </h2>
      <p class="mt-6 text-[16px] leading-[28px] text-navy">{body}</p>


      {/* No trailing arrow here — unlike the CTA strip's button, these
          measure 235 and 202 wide, i.e. label only. */}
      <div class="mt-6">
        <Button href={cta.href} label={cta.label} height={52} />
      </div>
    </div>
  </Reveal>

  {/* A horizontal row 1200 wide BELOW the block, not a column inside the text
      copy: measured at y=2143 and y=2766 on the homepage, all four items share
      a y and differ only in x. Rendering it as a vertical list inside the text
      column added ~300px at 768 and 390.
      Mobile: centre the list as a block (`w-fit mx-auto`) with items left-aligned,
      so the icons line up in one column under the centred title rather than each
      icon+label centring on its own. Full row again at md. */}
  {properties.length > 0 && (
    <div class="mx-auto mt-10 flex w-fit max-w-[1200px] flex-col gap-3 md:w-auto md:flex-row md:flex-wrap md:items-center md:justify-between md:gap-x-8">
      {properties.map((prop) => (
        <span class="flex items-center gap-3 text-[16px] text-navy">
          {prop.iconSvg && (
            <span
              class="inline-block size-[18px] shrink-0 [&>svg]:size-[18px] [&>svg]:fill-current"
              set:html={prop.iconSvg}
            />
          )}
          {prop.label}
        </span>
      ))}
    </div>
  )}
</section>
