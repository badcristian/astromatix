---
import GoCard from '../ui/GoCard.astro';
import Reveal from '../ui/Reveal.astro';
import copy from '../../i18n/home-copy.json';
import caseSchiphol from '../../assets/case-schiphol.jpg';
import caseJamwerkt from '../../assets/case-jamwerkt.jpg';
import caseFaam from '../../assets/case-faam.webp';

// Measured @1440:
//   section  y=3436 h=969, white, padding 100px 24px 0
//   h2       y=3536 x=151 w=1063, Poppins 700 30px/33px
//   card row y=3593 x=151 w=1138 — three 387px cells (-12px row margin),
//            each 12px padded, giving 363px cards
//
// The testimonial carousel that follows sits in the same section on the
// original; it is a separate component here.

const images = [caseSchiphol, caseJamwerkt, caseFaam];
const { caseSection } = copy;
---

<section class="px-6 pt-[100px]">
  <div class="mx-auto max-w-[1138px]">
    <h2 class="text-center font-display text-[30px] leading-[33px] font-bold text-navy">
      {caseSection.title}
    </h2>

    <Reveal variant="zoom" duration={500} class="mt-6 flex flex-wrap -mx-3">
      {/* Three per row from 768 up — the original does not break to two. */}
      {caseSection.cards.map((card, i) => (
        <div class="w-full px-3 md:w-1/3">
          <GoCard
            image={images[i]}
            name={card.name}
            title={card.title}
            href={card.href}
          />
        </div>
      ))}
    </Reveal>
  </div>
</section>
