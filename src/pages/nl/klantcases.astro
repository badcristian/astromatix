---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/sections/PageHero.astro';
import GoCard from '../../components/ui/GoCard.astro';
import ContactCta from '../../components/sections/ContactCta.astro';
import Reveal from '../../components/ui/Reveal.astro';
import LogoWall from '../../components/sections/LogoWall.astro';
import { resolveIcon } from '../../lib/icons';
import page from '../../i18n/pages/nl-klantcases.json';
import { ctaHeading } from '../../lib/cta';
import { bandFor, heroBand } from '../../lib/bands';

// The original ships no <h1> here (as on jobboost, over-ons and contact).
// We render one — three of five marketing pages share that defect, so it is
// systemic on their site and worth raising as a finding rather than copying.
// The original fuses the hero's title and its supporting line into one <h2>
// separated by a <br>, which the extractor flattens to a single string (see
// FINDINGS.md on <br> fusing words). Split it back into both halves — the
// subtitle used to read headings[1], which is the LOGO WALL's heading further
// down ("Tevreden klanten").
const heroRaw = page.headings.find((h) => h.startsWith('Samen succesvol')) ?? '';
const [heroTitle, heroSubtitle] = (() => {
  const i = heroRaw.indexOf('Bekijk');
  return i > 0
    ? [heroRaw.slice(0, i).trim(), heroRaw.slice(i).trim()]
    : [heroRaw || 'Klantcases', null];
})();
const cards = (page.goCards ?? []).map((c) => ({ ...c, img: resolveIcon(c.image) }));

// The LAST heading module here is "Tevreden klanten", which titles the logo
// wall — not the closing CTA. Take the CTA heading by content instead, or the
// page ships the wrong copy in the most prominent slot on it.
const ctaTitle =
  page.blocks.find((b: any) => b.heading?.startsWith('Benieuwd hoe jij'))?.heading ??
  'Benieuwd hoe jij jouw job marketing eenvoudig vanuit één plek kunt regelen?';

// Two case studies are linked at doubled /nl/nl/ paths on the original —
// migration artifacts. We serve them at the clean /nl/actueel/klantcase/ path,
// so the links have to be rewritten or they 404 in our own build.
const cleanHref = (href: string | null | undefined) =>
  (href ?? '#')
    .replace('/nl/nl/actueel/klantcase/', '/nl/actueel/klantcase/')
    .replace('/nl/nl/klantcase/', '/nl/actueel/klantcase/');
const tevredenHeading = page.headings.find((h) => h.startsWith('Tevreden')) ?? null;
---

<Base title={page.meta.title} description={page.meta.description ?? undefined}>
  <PageHero title={heroTitle} subtitle={heroSubtitle} />

  <section class="px-6 py-24">
    <div class="mx-auto max-w-[1138px]">
      <Reveal variant="zoom" duration={500} class="flex flex-wrap -mx-3">
        {cards.map((card) => card.img && (
          <div class="w-full px-3 md:w-1/3">
            <GoCard image={card.img} name={card.name} title={card.title} href={cleanHref(card.href)} />
          </div>
        ))}
      </Reveal>
    </div>
  </section>

  {/* "Tevreden klanten" titles the client logo wall on a #f5f5ff band — the
      heading rendered but the wall it introduces did not. This page has no
      .logos element of its own; it shares the site-wide LogoWall. */}
  {tevredenHeading && (
    <section class="px-6 pt-16" style={`background-color:${bandFor(page, "Tevreden") ?? "#f5f5ff"}`}>
      <h2 class="text-center font-display text-[30px] leading-[33px] font-bold text-navy">
        {tevredenHeading}
      </h2>
    </section>
  )}
  <div style={tevredenHeading ? `background-color:${bandFor(page, "Tevreden") ?? "#f5f5ff"}` : undefined}>
    <LogoWall />
  </div>

  <ContactCta title={ctaTitle} intro={null} band={bandFor(page, "Benieuwd hoe jij")} />
</Base>
