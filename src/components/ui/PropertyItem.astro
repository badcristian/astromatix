---
// The original's `.properties__item` — an icon plus a label. It recurs across
// the homepage hero band, the product-page bands, and voor-wie, so it lives in
// ui/ rather than inside any one section.
//
// Two icon treatments, both on the live original — do NOT unify them:
//   chip (homepage band)  `.icon--square.icon--fill`: an 18px NAVY glyph inside
//                         a 44×44 WHITE rounded square. Label white.
//   bare (product bands,  `.icon--medium`: a bare coloured glyph, no background.
//        voor-wie)        white 18px on the navy product bands; navy 29px in
//                         voor-wie's white list. Label matches the glyph.
//
// An earlier pass wrongly stripped the chip from ALL of them — right for the
// product bands, but the homepage band genuinely has the white square. Hence
// the `chip` prop. label sits 7px after the icon.
//
// Glyphs are our own equivalents of the theme's icon set, not traced copies.

interface Props {
  icon: 'download' | 'send' | 'expand' | 'arrow';
  label: string;
  variant?: 'light' | 'dark';
  size?: 'default' | 'small';
  /** White rounded-square background behind a navy glyph (the homepage band). */
  chip?: boolean;
}

const { icon, label, variant = 'light', size = 'default', chip = false } = Astro.props;

// Label colour follows the variant; the glyph is navy inside a white chip, else
// it matches the label. voor-wie's bare glyph is larger (29px).
const labelColor = variant === 'light' ? 'text-white' : 'text-navy';
const glyphColor = chip ? 'text-navy' : labelColor;
const glyphPx = chip ? 18 : variant === 'dark' ? 29 : 18;
const chipClass = chip ? 'size-11 rounded-lg bg-white' : '';

const paths: Record<Props['icon'], string> = {
  download: 'M12 3v11m0 0l-4-4m4 4l4-4M4 19h16',
  send: 'M21 3L3 10.5l7 3 3 7L21 3z',
  expand: 'M12 3v18M3 12h18M8 7l4-4 4 4M8 17l4 4 4-4M7 8l-4 4 4 4M17 8l4 4-4 4',
  arrow: 'M4 12h15m0 0l-5-5m5 5l-5 5',
};

const labelClass = size === 'small' ? 'text-[14px] leading-[20px]' : 'text-[16px] leading-[22.4px]';
---

<div class="inline-flex items-center gap-[7px]">
  <span class:list={['flex shrink-0 items-center justify-center', chipClass, glyphColor]}>
    <svg
      width={glyphPx}
      height={glyphPx}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d={paths[icon]} />
    </svg>
  </span>
  <span class={`${labelClass} ${labelColor}`}>{label}</span>
</div>
