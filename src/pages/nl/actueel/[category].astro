---
import Base from '../../../layouts/Base.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import ArticleListing from '../../../components/sections/ArticleListing.astro';
import ContactCta from '../../../components/sections/ContactCta.astro';
import listing from '../../../i18n/pages/listing.json';

// The original ships /nl/actueel/{blogs,nieuws,kennis,events} as four
// byte-identical 115,751-byte copies of /nl/actueel — same empty <div>, same
// client-side List.js, no server-side filtering at all (FINDINGS.md §6).
//
// Here each is a real, server-filtered, crawlable page at the same URL.

export function getStaticPaths() {
  return listing.categories.map((category) => ({
    params: { category: category.toLowerCase() },
    props: { category },
  }));
}

const { category } = Astro.props;
const count = listing.items.filter((i) => i.category === category).length;
---

<Base
  title={`${category} — Jobmatix`}
  description={`${category} van Jobmatix — ${count} ${count === 1 ? 'bericht' : 'berichten'}.`}
>
  <PageHero title={category} />
  <ArticleListing activeCategory={category} />
  <ContactCta intro={null} />
</Base>
