---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SearchPanel from '../components/layout/SearchPanel.astro';
import faviconSrc from '../assets/favicon.png';
import { SITE } from '../lib/seo';

// The source is 4667x4667; generate the sizes browsers actually ask for
// rather than shipping a 98KB PNG to every tab.
const favicon32 = await getImage({ src: faviconSrc, width: 32, height: 32, format: 'png' });
const favicon180 = await getImage({ src: faviconSrc, width: 180, height: 180, format: 'png' });

interface Props {
  title: string;
  description?: string;
  /**
   * Override the canonical URL. Defaults to the page's own path; the doubled
   * /nl/nl/ klantcase routes point theirs at the clean path so the duplicate
   * URL doesn't compete with it in search.
   */
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site ?? SITE).href;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={favicon180.src} />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />

    {/* Indexable by default — stated explicitly so it can't be mistaken for an
        oversight, and so a production deploy works without flipping anything.
        See src/lib/seo.ts / FINDINGS.md #38. */}
    <meta name="robots" content="index, follow" />

    {/* Open Graph / Twitter — parity with the original's social tags. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Jobmatix" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    {/* Set before first paint so reveal elements start hidden without a flash.
        Gating the hidden state on this class means a JS failure leaves the page
        visible rather than blank. */}
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <Header />
    <SearchPanel />
    {/* data-pagefind-body scopes the search index to page content — the
        Header, SearchPanel and Footer chrome are excluded from results. */}
    <main data-pagefind-body>
      {/* Pin the search-result title to the clean page <title>. Without this
          Pagefind derives it from the first <h1>, whose two-tone spans run
          together ("KruidvatDe juiste…") and can absorb an in-heading CTA. */}
      <span data-pagefind-meta="title" class="sr-only">{title}</span>
      <slot />
    </main>
    <Footer />

    <script>
      // Reveal-on-scroll. Registered once for the whole page.
      const reveals = document.querySelectorAll<HTMLElement>('.reveal');

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduced || !('IntersectionObserver' in window)) {
        // Nothing to animate — make sure everything is visible regardless.
        reveals.forEach((el) => el.classList.add('reveal--done'));
      } else {
        const observer = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add('reveal--done');
              // One-shot: the original does not re-hide on scroll back up.
              obs.unobserve(entry.target);
            }
          },
          { threshold: 0.15 },
        );
        reveals.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
