---
import { Image } from 'astro:assets';
import { resolveIcon } from '../../lib/icons';

// The klantcases "Tevreden klanten" `.module--review` carousel. Read from the
// live Splide: type loop, perPage 3 (→ 1 at/below 1139), perMove 1, gap 24,
// autoplay 8s. Each slide is a WHITE CARD (337×354, 24px radius, soft navy
// shadow, 24px padding): the quote on top, then an 80px round avatar beside the
// name (500) and company. Left-aligned. A lightweight translateX carousel
// rather than Splide, matching PhotoCarousel.

interface Props {
  reviews: {
    quote: string | null;
    name: string | null;
    company: string | null;
    avatar: string | null;
  }[];
}

const { reviews } = Astro.props;
const slides = reviews
  .map((r) => ({ ...r, img: resolveIcon(r.avatar) }))
  .filter((r) => r.quote);
---

{slides.length > 0 && (
  <section class="px-6 pb-24">
    <div class="relative mx-auto max-w-[1104px] px-12" data-review-carousel>
      <button
        type="button"
        class="absolute top-1/2 left-0 z-10 -translate-y-1/2 text-navy transition-opacity hover:opacity-60"
        aria-label="Vorige"
        data-prev
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 5l-7 7 7 7" />
        </svg>
      </button>

      <div class="overflow-hidden">
        <div class="flex items-stretch gap-6 transition-transform duration-[450ms] ease-out" data-track>
          {slides.map((r) => (
            <div class="w-full shrink-0 lg:w-[calc((100%-48px)/3)]">
              <div class="flex h-full flex-col rounded-3xl bg-white p-6 shadow-[0_16px_32px_0_rgba(17,65,122,0.05),0_8px_16px_0_rgba(17,65,122,0.05)]">
                <p class="text-[14.4px] leading-[20.16px] text-navy">{r.quote}</p>
                <div class="mt-auto flex items-center gap-4 pt-6">
                  {r.img && (
                    <Image src={r.img} alt="" width={80} height={80} densities={[1, 2]} class="size-20 shrink-0 rounded-full object-cover" />
                  )}
                  <div>
                    {r.name && <p class="text-[14.4px] leading-[20px] font-medium text-navy">{r.name}</p>}
                    {r.company && <p class="text-[14.4px] leading-[20px] text-navy">{r.company}</p>}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <button
        type="button"
        class="absolute top-1/2 right-0 z-10 -translate-y-1/2 text-navy transition-opacity hover:opacity-60"
        aria-label="Volgende"
        data-next
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <div class="mt-8 flex justify-center gap-2" data-review-dots></div>
    </div>
  </section>
)}

<script>
  import { pagedCarousel } from '../../lib/carousel';

  document.querySelectorAll<HTMLElement>('[data-review-carousel]').forEach((root) =>
    pagedCarousel(root, {
      track: '[data-track]',
      dots: '[data-review-dots]',
      prev: '[data-prev]',
      next: '[data-next]',
      // 3 cards above 1140, 1 below (Splide breakpoints 1139 / 767 → perPage 1).
      breakpoint: 1140,
      interval: 8000,
      dotClass: 'size-2 rounded-full bg-navy/20 transition-colors data-[active]:bg-navy',
    }),
  );
</script>
