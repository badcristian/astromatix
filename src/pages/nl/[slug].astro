---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/sections/PageHero.astro';
import QuickFeat from '../../components/ui/QuickFeat.astro';
import FeatureCard from '../../components/ui/FeatureCard.astro';
import FormStub from '../../components/ui/FormStub.astro';
import GoCard from '../../components/ui/GoCard.astro';
import Button from '../../components/ui/Button.astro';
import LogoWall from '../../components/sections/LogoWall.astro';
import { Image } from 'astro:assets';
import { resolveIcon } from '../../lib/icons';
import { LANDING_SLUGS } from '../../lib/landing';
import { bandFor } from '../../lib/bands';

// The 13 funnel and thank-you pages, from one data-driven template.
//
// They are the thinnest pages on the site and share a module vocabulary of
// eight types, but they do NOT all share a shape: some open with a hero-slider
// and some with a section-intro, four carry a quickfeat, two carry a booking
// embed instead of a form, and the bedankt-* pages carry neither. So rather
// than branch per page, this renders whichever sections the extractor found,
// in a fixed order. Adding a fourteenth page is a data change, not a code one.
//
// Routing note: Astro gives static routes priority over dynamic ones, so this
// cannot shadow contact.astro / platform.astro / over-ons.astro et al. The
// slug list is explicit anyway — see src/lib/landing.ts.
//
// NO ContactCta HERE. These pages ARE the call to action — each one already
// carries its own form (or a booking embed, or go-cards). Appending the shared
// strip gave /nl/demo-aanvragen TWO forms where the original has one, repeated
// its heading verbatim in both places, and added 856px to a 1670px page.

const pages = import.meta.glob<{ default: any }>('../../i18n/pages/nl-*.json', { eager: true });

export function getStaticPaths() {
  return LANDING_SLUGS.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const key = Object.keys(pages).find((p) => p.endsWith(`/nl-${slug}.json`));
if (!key) throw new Error(`No extractor output for landing page "${slug}"`);
const d = pages[key].default;

const blocks: any[] = d.blocks ?? [];
const intro = d.sectionIntros?.[0] ?? null;
const slide = d.heroSlider?.[0] ?? null;

// Nine of these thirteen pages ship no <h1> (FINDINGS.md §5). Take the best
// title available and render it as one — same deliberate divergence PageHero
// documents.
const title =
  slide?.title ?? intro?.title ?? blocks.find((b) => b.heading)?.heading ?? '';

// bedankt-contact's <title> on the original is the literal string
// "nl/bedankt-contact" — an unfilled field, not a title. Fall back to the
// page's own heading rather than shipping a path as a browser tab label.
const looksLikePath = /^\/?[a-z]+\/[a-z-]+$/i.test(d.meta.title ?? '');
const metaTitle = looksLikePath || !d.meta.title ? `${title} — Jobmatix` : d.meta.title;

// Sections keep their own headings rather than being flattened into a wall of
// paragraphs. An earlier version collected only the body text, which silently
// dropped headings like "Plan een demo en ontdek wat ons platform voor jouw
// bedrijf kan betekenen" — copy loss a pixel diff would never catch, because
// the page still reflowed to a plausible height.
// Drop the title's own HEADING (PageHero already renders it) but KEEP its
// body. Filtering the whole block discarded all eleven paragraphs of
// /nl/privacy-statement, which shipped as a page with a heading and nothing
// else — and no measurement caught it, because the heading was present and
// correct.
const sections = blocks
  .filter((b) => b.heading || b.body?.length)
  .map((b) => ({
    heading: b.heading === title ? null : (b.heading as string | null),
    level: b.level,
    body: b.body ?? [],
  }))
  .filter((b) => b.heading || b.body.length);

// section-intro carries its own lead paragraph outside the block outline.
const introBody = intro?.body ? [intro.body] : [];

const form = d.forms?.[0] ?? null;
const contact = d.teamCards?.[0] ?? null;
const portrait = resolveIcon(contact?.image);
const featureCards = (d.featureCards ?? [])
  .map((c: any) => ({ ...c, resolved: resolveIcon(c.icon) }))
  .filter((c: any) => c.title);
const logos = (d.logos ?? []).map((l: any) => ({ ...l, resolved: resolveIcon(l.src) })).filter((l: any) => l.resolved);

// demo-emile and meeting-koen embed HubSpot's Meetings scheduler in an iframe
// rather than carrying a form. We do not embed it: it is a third-party frame
// that loads HubSpot tracking, and this is a pitch demo of a HubSpot
// replacement. Same call as the Google Maps omission — FINDINGS.md §22.
const usesBookingEmbed = ['demo-emile', 'meeting-koen'].includes(slug!);

// The long-form legal pages set their text column to 1200 on the original, not
// the 850 the funnel pages use. Measured: 1200px across 144 paragraphs.
const wide = ['privacy-statement', 'algemene-voorwaarden'].includes(slug!);
// The funnel pages run their intro column at 928, not 850. Legal pages go
// wider still (1200), measured across 144 paragraphs.
const colClass = wide ? 'mx-auto max-w-[1200px]' : 'mx-auto max-w-[928px]';

// Tables anchored to the heading they follow.
const tablesFor = (heading: string | null) =>
  (d.tables ?? []).filter((t: any) => (t.afterHeading ?? null) === heading);

// Rich-text pages (privacy-statement) render their sanitised HTML body, which
// preserves <strong> runs and the <br> line breaks the plain-text walker lost.
const richBody: string | null = d.richBody ?? null;

// Legal pages get a shorter dark hero on the original (~compact banner) rather
// than the tall 200px-padded interior hero the funnel pages use.
const compactHero = wide;
---

<Base title={metaTitle} description={d.meta.description || undefined}>
  {compactHero ? (
    <section class="bg-navy px-6 pt-[120px] pb-10 text-center text-white">
      <div class="container-site">
        <h1 class="font-display text-[40px] leading-[48px] font-bold text-white">{title}</h1>
      </div>
    </section>
  ) : (
    <PageHero title={title} subtitle={slide?.body ?? null} background={d.hero?.background} />
  )}

  {richBody && (
    <section class="px-6 py-12">
      <div class:list={['rich-text legal', colClass]} set:html={richBody} />
    </section>
  )}

  {!richBody && (introBody.length > 0 || sections.length > 0) && (
    <section class="px-6 py-12">
      <div class:list={[colClass]}>
        {introBody.map((para) => (
          <p class="mb-4 text-[16px] leading-[26px] text-navy">{para}</p>
        ))}
        {sections.map((s) => (
          <>
            {s.heading && (
              <h2 class="mt-8 mb-4 font-display text-[30px] leading-[33px] font-bold text-navy first:mt-0">
                {s.heading}
              </h2>
            )}
            {s.body.map((para) => (
              <p class="mb-4 text-[16px] leading-[26px] text-navy">{para}</p>
            ))}
            {tablesFor(s.heading).map((table: any) => (
              <div class="mb-8 overflow-x-auto">
                <table class="w-auto border-collapse text-[16px] text-navy">
                  <tbody>
                    {table.rows.map((row: string[], ri: number) => (
                      <tr>
                        {row.map((cell) =>
                          ri === 0 ? (
                            <th class="border border-navy/15 bg-mist px-4 py-2 text-left font-bold">
                              {cell}
                            </th>
                          ) : (
                            <td class="border border-navy/15 px-4 py-2">{cell}</td>
                          ),
                        )}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ))}
          </>
        ))}
      </div>
    </section>
  )}

  {featureCards.length > 0 && (
    <section class="px-6 pb-12">
      <div class="mx-auto flex max-w-[1138px] flex-wrap -mx-3">
        {featureCards.map((card: any) => (
          <div class="w-full px-3 pb-6 md:w-1/2 lg:w-1/3">
            <FeatureCard
              icon={card.resolved}
              title={card.title}
              body={card.body ?? ''}
              background="white"
            />
          </div>
        ))}
      </div>
    </section>
  )}

  {d.quickfeat?.length > 0 && (
    <section class="bg-mist px-6 py-20">
      <div class="mx-auto max-w-[1138px]">
        <QuickFeat items={d.quickfeat} />
      </div>
    </section>
  )}

  {form && (
    <section class="px-6 py-16">
      <div class="mx-auto max-w-[850px]">
        <FormStub
          fields={form.fields
            .filter((f: any) => f.name)
            .map((f: any) => ({
              name: f.name,
              type: f.type,
              label: f.label ?? f.placeholder ?? f.name,
              required: f.required,
            }))}
          submitLabel={form.submitLabel ?? 'Verzenden'}
        />
      </div>
    </section>
  )}

  {usesBookingEmbed && (
    <section class="px-6 py-16">
      <div class="mx-auto max-w-[850px] rounded-3xl bg-fog p-10 text-center">
        <p class="font-display text-[20px] leading-[28px] font-bold text-navy">
          Agenda inplannen
        </p>
        <p class="mt-3 text-[16px] leading-[26px] text-navy/70">
          Not fully implemented yet — de originele pagina laadt hier HubSpot Meetings.
        </p>
      </div>
    </section>
  )}

  {contact && (
    <section class="px-6 pb-16">
      <div class="mx-auto flex max-w-[850px] flex-wrap items-center gap-5">
        {portrait && (
          <Image src={portrait} alt="" width={96} height={96} class="size-24 rounded-full object-cover" />
        )}
        <div>
          {contact.name && (
            <p class="font-display text-[20px] leading-[28px] font-bold text-navy">{contact.name}</p>
          )}
          {contact.body && <p class="text-[14.4px] text-navy/70">{contact.body}</p>}
          <p class="mt-2 flex flex-wrap gap-4 text-[14.4px]">
            {(contact.links ?? [])
              .filter((l: any) => /^(mailto|tel):/.test(l.href ?? ''))
              .map((l: any) => (
                <a href={l.href} class="text-orange hover:underline">
                  {l.href.replace(/^(mailto|tel):/, '')}
                </a>
              ))}
          </p>
        </div>
      </div>
    </section>
  )}

  {d.goCards?.length > 0 && (
    <section class="px-6 pb-16">
      <div class="mx-auto flex max-w-[1138px] flex-wrap -mx-3">
        {d.goCards.map((card: any) => (
          <div class="w-full px-3 pb-6 md:w-1/2 lg:w-1/3">
            <GoCard
              title={card.title}
              name={card.name}
              href={card.href}
              image={resolveIcon(card.image)}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  {/*
    The original presents the wall as a six-at-a-time carousel (169px tall) on
    a #f5f5ff band, not a wrapped grid on white.
  */}
  {logos.length > 0 && (
    <div style={`background-color:${bandFor(d, 'Plan een demo') ?? '#f5f5ff'}`}>
      <LogoWall />
    </div>
  )}
</Base>

<style>
  /* Prose for the legal rich-text bodies (privacy-statement). Preserves the
     bold section labels and the <br> line breaks in the Contactgegevens block,
     both of which the plain-text walker had flattened. */
  .legal {
    color: var(--color-navy);
    font-size: 16px;
    line-height: 26px;
  }
  .legal :global(p) { margin-bottom: 1.25rem; }
  .legal :global(strong) { font-weight: 700; }
  .legal :global(h2), .legal :global(h3) {
    font-family: var(--font-display);
    font-weight: 700;
    margin: 2rem 0 0.75rem;
  }
  .legal :global(h2) { font-size: 24px; line-height: 30px; }
  .legal :global(h3) { font-size: 20px; line-height: 28px; }
  .legal :global(ul), .legal :global(ol) { margin: 0 0 1.25rem 1.25rem; }
  .legal :global(ul) { list-style: disc; }
  .legal :global(ol) { list-style: decimal; }
  .legal :global(li) { margin-bottom: 0.5rem; }
  .legal :global(a) { color: var(--color-orange); text-decoration: underline; }
  .legal :global(table) {
    border-collapse: collapse;
    margin: 1.5rem 0;
    display: block;
    overflow-x: auto;
  }
  .legal :global(th), .legal :global(td) {
    border: 1px solid color-mix(in srgb, var(--color-navy) 15%, transparent);
    padding: 0.5rem 1rem;
    text-align: left;
  }
  .legal :global(th) { background: var(--color-mist); font-weight: 700; }
</style>
