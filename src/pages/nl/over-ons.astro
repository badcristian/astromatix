---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/sections/PageHero.astro';
import FeatureBand from '../../components/sections/FeatureBand.astro';
import FeatureCard from '../../components/ui/FeatureCard.astro';
import ContactCta from '../../components/sections/ContactCta.astro';
import Reveal from '../../components/ui/Reveal.astro';
import Timeline from '../../components/ui/Timeline.astro';
import { Image } from 'astro:assets';
import { resolveIcon } from '../../lib/icons';
import page from '../../i18n/pages/nl-over-ons.json';
import { ctaHeading } from '../../lib/cta';
import { bandFor, heroBand } from '../../lib/bands';

// No <h1> on the original — rendered here deliberately.
const bandIcons = ['download', 'expand', 'send', 'arrow'] as const;
const band = page.properties.map((p, i) => ({ icon: bandIcons[i % 4], label: p.label }));

// Headings by content, not index — see jobadvertising.astro. The hero SUBTITLE was reading headings[2], which is the
// "Ons verhaal" section heading further down the page — the same string then
// rendered twice. The hero's real supporting copy is the body under its own
// heading.
const heading = (prefix: string) =>
  page.headings.find((h) => h.toLowerCase().startsWith(prefix.toLowerCase())) ?? null;
const block = (prefix: string) =>
  page.blocks?.find((b: any) => b.heading?.toLowerCase().startsWith(prefix.toLowerCase())) ?? null;

const heroBlock = block('Alles over Jobmatix');

// Two content photos the page carries that were not rendered: a team photo in
// the intro (384x307, under "Alles over Jobmatix") and a portrait beside the
// closing quote (384x384, under "Maak deel uit…").
const introImage = (() => {
  const hit = (page.contentImages ?? []).find(
    (i: any) => i.afterHeading?.startsWith('Alles over') && i.width > 300,
  );
  const r = resolveIcon(hit?.src);
  return r ? { ...hit, resolved: r } : null;
})();
const quoteBlock = block('"De positieve reacties');
const quoteImage = (() => {
  const hit = (page.contentImages ?? []).find(
    (i: any) => i.afterHeading?.startsWith('Maak deel') && i.width > 300,
  );
  const r = resolveIcon(hit?.src);
  return r ? { ...hit, resolved: r } : null;
})();
---

<Base title={page.meta.title} description={page.meta.description ?? undefined}>
  <PageHero title={heroBlock?.heading ?? 'Over ons'} subtitle={heroBlock?.body?.[0] ?? null} />
  {band.length > 0 && <FeatureBand items={band} />}

  {introImage && (
    <section class="px-6 pt-12">
      <div class="mx-auto max-w-[1200px]">
        <Image
          src={introImage.resolved}
          alt=""
          width={introImage.width}
          height={introImage.height}
          class="mx-auto h-auto w-full max-w-[900px] rounded-3xl"
        />
      </div>
    </section>
  )}

  <section class="px-6 py-24">
    <div class="mx-auto max-w-[1200px]">
      <h2 class="text-center font-display text-[30px] leading-[33px] font-bold text-navy">
        {heading('Onze kernwaarden') ?? ''}
      </h2>
      <Reveal variant="zoom" duration={1000} class="mt-11 flex flex-wrap justify-center -mx-3">
        {page.featureCards.map((card) => (
          <div class="w-full px-3 md:w-1/2 lg:w-1/3">
            <FeatureCard icon={resolveIcon(card.icon)} title={card.title} body={card.body} />
          </div>
        ))}
      </Reveal>
    </div>
  </section>
    {/* fog (#f8f9fb) on the original, not mist. */}
  {page.timeline && (
    <section class="px-6 py-[50px]" style={`background-color:${bandFor(page, 'Onze kernwaarden') ?? '#f8f9fb'}`}>
      <div class="mx-auto max-w-[1200px]">
        <h2 class="mb-10 text-center font-display text-[30px] leading-[38px] font-bold text-navy">
          {heading('Ons verhaal') ?? 'Ons verhaal'}
        </h2>
        <Timeline items={page.timeline} />
      </div>
    </section>
  )}

  {quoteBlock?.body?.[0] && (
    <section class="px-6 py-16">
      <figure class="mx-auto flex max-w-[1000px] flex-col items-center gap-8 lg:flex-row">
        {quoteImage && (
          <Image
            src={quoteImage.resolved}
            alt=""
            width={quoteImage.width}
            height={quoteImage.height}
            class="h-auto w-full rounded-3xl lg:w-[384px] lg:shrink-0"
          />
        )}
        <blockquote class="text-[20px] leading-[30px] text-navy">
          {quoteBlock.heading?.replace(/^"|"$/g, '')}
          <footer class="mt-4 text-[16px] text-navy/70">{quoteBlock.body[0]}</footer>
        </blockquote>
      </figure>
    </section>
  )}

  <ContactCta title={ctaHeading(page, "over-ons")} intro={null} band={bandFor(page, "Maak deel uit")} />
</Base>
