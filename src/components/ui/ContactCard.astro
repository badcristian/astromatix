---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// The floating contact card the funnel pages put beside their form (Emile
// Serruys on demo-aanvraag / advies-gesprek / demo-aanvragen, Koen Somers on
// demo-day-actie / jobmarketing-scan). Measured @1440 on demo-aanvraag:
//   card     ~293 wide, white, 24px radius, the theme's soft navy shadow
//   portrait 100×100 round, centred
//   name     Poppins 700 ~18px navy; role Manrope 16px navy
//   socials  three orange glyphs in small white circles, centred row

interface Props {
  name: string;
  /** e.g. "New Business Development" — stored in the extractor's `body`. */
  role?: string | null;
  portrait?: ImageMetadata;
  links?: { href: string | null }[];
}

const { name, role = null, portrait, links = [] } = Astro.props;

type Kind = 'linkedin' | 'mail' | 'phone' | 'link';
const kindOf = (href: string): Kind =>
  /linkedin\./i.test(href) ? 'linkedin'
  : href.startsWith('mailto:') ? 'mail'
  : href.startsWith('tel:') ? 'phone'
  : 'link';

const socials = links
  .filter((l): l is { href: string } => !!l.href)
  .map((l) => ({ href: l.href, kind: kindOf(l.href) }));

const glyphs: Record<Kind, string> = {
  linkedin: '<path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5 2.5 2.5 0 0 0 4.98 3.5zM3 9.5h4V21H3zM10 9.5h3.8v1.57h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.75V21h-4v-4.9c0-1.17-.02-2.68-1.9-2.68-1.9 0-2.2 1.28-2.2 2.6V21h-4z"/>',
  mail: '<path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm9 7L3.5 6.5v-.4L12 11l8.5-4.9v.4z" fill="currentColor" stroke="none"/><path d="M2.5 6.2 12 12l9.5-5.8" fill="none" stroke="currentColor" stroke-width="1.6"/>',
  phone: '<path d="M6.6 3H4.2a1 1 0 0 0-1 1.1c.3 3 1.5 5.8 3.4 8 1.9 2.2 4.4 3.7 7.2 4.5a1 1 0 0 0 1.2-.8l.5-2.3a1 1 0 0 0-.6-1.1l-2.5-1a1 1 0 0 0-1.1.25l-.8.9a10.5 10.5 0 0 1-3.8-3.8l.9-.8a1 1 0 0 0 .25-1.1l-1-2.5A1 1 0 0 0 6.6 3z" fill="currentColor" stroke="none"/>',
  link: '<path d="M10 13a5 5 0 0 0 7 0l2-2a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-2 2a5 5 0 0 0 7 7l1-1"/>',
};

const labels: Record<Kind, string> = {
  linkedin: 'LinkedIn',
  mail: 'E-mail',
  phone: 'Bellen',
  link: 'Link',
};
---

<div class="rounded-3xl bg-white p-8 text-center shadow-card-lg">
  {portrait && (
    <Image
      src={portrait}
      alt=""
      width={100}
      height={100}
      densities={[1, 2]}
      class="mx-auto size-[100px] rounded-full object-cover"
    />
  )}
  <p class="mt-4 font-display text-[18px] leading-[24px] font-bold text-navy">{name}</p>
  {role && <p class="mt-1 text-[16px] leading-[22px] text-navy">{role}</p>}

  {socials.length > 0 && (
    <div class="mt-4 flex justify-center gap-3">
      {socials.map((s) => (
        <a
          href={s.href}
          aria-label={labels[s.kind]}
          class="flex size-9 items-center justify-center rounded-full text-orange shadow-[0_8px_16px_0_rgba(17,65,122,0.08)] transition-opacity hover:opacity-70"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0" aria-hidden="true" set:html={glyphs[s.kind]} />
        </a>
      ))}
    </div>
  )}
</div>
