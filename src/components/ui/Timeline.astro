---
import { Image } from 'astro:assets';
import { resolveIcon } from '../../lib/icons';

// The original's `.module--timeline`. Measured @1440 on /nl/over-ons:
//   module  1200 wide, 2305 tall across 9 items
//   item    1200 wide, ~220 tall, alternating sides of a centre bar
//   box     552 wide (half the track), 24px inner padding
//   badge   date pill above the title
//   title   28px bold, body 14.4px
//   image   151x101 beside the text
//   dot     30x30 on the centre bar
//
// Rendered as an ordered list: it is a chronology, so the numbering is
// meaningful to assistive tech even though it is visually suppressed.

interface Props {
  items: { badge: string | null; title: string | null; body: string | null; image?: string | null }[];
}
const { items } = Astro.props;
---

<ol class="relative mx-auto max-w-[1200px] list-none">
  {/* centre bar */}
  {/* TWO different breakpoints here, both measured on the original:
        >= 768  cards alternate around the centre line (x=48 / x=456 at 768)
        >= 1140 the image sits BESIDE the text inside the card
      Between 768 and 1139 the layout alternates but the card stacks its own
      image above its text. Collapsing both to `lg:` left over-ons -1706 at
      768; collapsing both to full-width sent it to +3021. */}
  <li aria-hidden="true" class="absolute inset-y-0 left-1/2 hidden w-px -translate-x-1/2 bg-navy/15 md:block"></li>

  {items.map((item, i) => {
    const img = resolveIcon(item.image);
    const right = i % 2 === 1;
    return (
      <li class="relative mb-10 lg:mb-6">
        <div class:list={['md:flex', right ? 'md:justify-end' : 'md:justify-start']}>
          <div class="rounded-3xl bg-white p-6 shadow-card md:w-[312px] lg:w-[552px]">
            {/* Below 1140 the card STACKS: the image goes to the card's full
                width and the text sits under it. Measured on the original —
                image 151x101 beside 353px of text at 1440, but 264x176 above
                264px of text at 768 and 294x196 at 390. Keeping the desktop
                side-by-side layout at every width left each of nine items
                200-350px short, which was most of over-ons' -1706 at 768.

                `lg:items-center` is load-bearing: the original's
                `.timeline__content` is `align-items:center` (valign-center).
                Without it this flex row falls back to `align-items:stretch`,
                which stretches the h-auto image to the taller text column's
                height — with the img default object-fit:fill that visibly
                distorts every photo vertically (worst on the portrait
                kantoor.jpg, 1536x2048). */}
            <div class="mt-3 flex flex-col gap-4 lg:flex-row lg:items-center lg:gap-6">
              <div class="min-w-0 flex-1">
                {item.title && (
                  <h3 class="font-display text-[28px] leading-[35px] font-bold text-navy">
                    {item.title}
                  </h3>
                )}
                {item.body && (
                  <p class="mt-2 text-[14.4px] leading-[20.16px] text-navy">{item.body}</p>
                )}
              </div>
              {/* Intrinsic dimensions, not a forced 3:2 crop — these images do
                  not share an aspect ratio (one is 151x202 where the rest are
                  151x101) and the original simply pins the width and lets the
                  height follow. */}
              {img && (
                <Image
                  src={img}
                  alt=""
                  width={img.width}
                  height={img.height}
                  class="h-auto w-full rounded-xl lg:w-[151px] lg:shrink-0"
                />
              )}
            </div>
          </div>
        </div>

        {/* Dot on the centre bar — a navy ring — plus the date as a navy pill
            beside it, on the card's EMPTY side (right of the dot for a left
            card, left of the dot for a right card), matching the original. */}
        <span
          aria-hidden="true"
          class="absolute top-8 left-1/2 hidden size-[18px] -translate-x-1/2 rounded-full border-[3px] border-navy bg-white md:block"
        ></span>
        {item.badge && (
          <span
            class:list={[
              'absolute top-[30px] hidden rounded-full bg-navy px-3 py-1 text-[13px] font-medium whitespace-nowrap text-white md:inline-block',
              right ? 'right-1/2 mr-5' : 'left-1/2 ml-5',
            ]}
          >
            {item.badge}
          </span>
        )}
      </li>
    );
  })}
</ol>
