---
import { resolveIcon } from '../../lib/icons';
import { Image } from 'astro:assets';

// The original's `.quickfeat`. Measured @1440 on /nl/oplossingen/jobboost:
//   grid   col s4 md-s6 sm-s12 — three across, 379px columns
//   item   355 wide: a 29px icon column beside a 326px text column
//   title  h4, Poppins 700 20px, up to 458 wide (254 in the denser 3-up grid)
//   desc   Manrope 14.4px, up to 458 wide
//
// Icons are inline SVG in the theme rather than <img>, so the extractor finds
// no URL for them. Falls back to a shared glyph until they are traced.

interface Props {
  items: { title: string | null; body: string | null; icon?: string | null }[];
  /**
   * Columns at lg. The original genuinely differs by page: the klantcases run
   * two across (588px items, text up to 458 wide) while the product pages run
   * three (355px items). A 3-up grid on a klantcase squeezed the text to ~331
   * against the original's 458.
   */
  columns?: 2 | 3;
}

const { items, columns = 3 } = Astro.props;
const colClass = columns === 2 ? 'lg:w-1/2' : 'lg:w-1/3';
---

<div class="flex flex-wrap -mx-3">
  {items.map((item) => {
    const icon = resolveIcon(item.icon);
    return (
      <div class:list={['w-full px-3 pb-12 md:w-1/2', colClass]}>
        <div class="flex gap-6">
        {/* The original's icon is a NAVY right-arrow (theme `arrow-right`,
            icon--accent), not an orange check. */}
        <span class="mt-1 size-[29px] shrink-0 text-navy" aria-hidden="true">
          {icon ? (
            <Image src={icon} alt="" width={29} densities={[1, 2]} />
          ) : (
            <svg width="29" height="29" viewBox="0 0 448 512" fill="currentColor" aria-hidden="true">
              <path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z" />
            </svg>
          )}
        </span>

          <div class="max-w-[458px]">
            {item.title && (
              <h4 class="font-display text-[20px] leading-[28px] font-bold text-navy">
                {item.title}
              </h4>
            )}
            {item.body && (
              <p class="mt-2 text-[14.4px] leading-[20.16px] text-navy">{item.body}</p>
            )}
          </div>
        </div>
      </div>
    );
  })}
</div>
