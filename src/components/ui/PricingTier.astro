---
import Button from './Button.astro';

// The original's `.pricing__box`. Measured @1440 on /nl/oplossingen/jobboost:
//   plan column  408 wide (col s4 md-s6 sm-s12), 12px side padding
//   box          384×566, white, 24px radius, padding 24px 36px 40px
//   inner        title, tag, price, info, desc, feature list, CTA, disclaimer
//
// Feature rows use a real <ul>, so screen readers announce the count — the
// original renders them as divs.

interface Props {
  title: string | null;
  price: string | null;
  /** The small suffix beside the price ("per boost"). */
  info: string | null;
  desc: string | null;
  features: string[];
  cta: { label: string; href: string } | null;
  disclaimer: string | null;
}

// `tag` from the extractor ("€399 per boost") duplicates price + info, so it is
// intentionally not destructured/rendered.
const { title, price, info, desc, features, cta, disclaimer } = Astro.props;

// The original CTA href is "/jobboost#Contactjobboost" — a cross-page link on
// their site. On our page the button should scroll to the form at the bottom,
// so keep only the #anchor and point it at the CTA form's id.
const ctaHref = (cta?.href ?? '#').replace(/^[^#]*/, '') || '#';
---

<div class="flex h-full flex-col rounded-3xl bg-white px-9 pt-6 pb-10 shadow-card-lg">
  {title && (
    <h3 class="font-display text-[20px] leading-[28px] font-bold text-navy">{title}</h3>
  )}

  {/* Price row: the big number (59px Manrope bold on the original, not 40px
      Poppins) with a small "per boost" suffix on the same baseline, exactly as
      the original renders it. */}
  {price && (
    <div class="mt-4 flex items-baseline gap-1.5">
      <p class="text-[59px] leading-[59px] font-bold text-navy">{price}</p>
      {info && <span class="text-[14.4px] leading-[20px] text-navy">{info}</span>}
    </div>
  )}
  {desc && <p class="mt-4 text-[16px] leading-[22.4px] text-navy">{desc}</p>}

  {features.length > 0 && (
    <ul class="mt-6 flex flex-col gap-3">
      {features.map((feature) => (
        <li class="flex items-start gap-3 text-[16px] leading-[22.4px] text-navy">
          <svg
            class="mt-[3px] shrink-0 text-orange"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 12l6 6L20 6" />
          </svg>
          {feature}
        </li>
      ))}
    </ul>
  )}

  {/* mt-auto keeps the CTA on the baseline across tiers of unequal length. */}
  {cta && (
    <div class="mt-auto pt-8">
      <Button href={ctaHref} label={cta.label} height={52} variant="navy" class="w-full justify-center" />
    </div>
  )}

  {disclaimer && (
    <p class="mt-3 text-[14px] leading-[20px] text-navy/60">{disclaimer}</p>
  )}
</div>
