---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Measured @1440:
//   section  1440×169, padding 40px 24px
//   carousel 1000 wide, padding 0 48px (arrows sit in that padding)
//   track    904 wide, 89 tall, showing six logos at a time
//   logo     131×65, vertically centred in the 89px slide
//
// 18 logos on the original, presented as a loop with clone slides. Built with
// the same lightweight translateX carousel as the testimonials rather than
// pulling in Splide.

// Astro.glob was removed; import.meta.glob is the current API.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/logos/*.png',
  { eager: true },
);
const images = Object.keys(modules)
  .sort()
  .map((path) => modules[path].default);

const PER_VIEW = 6;
---

<section class="px-6 py-10">
  <div class="relative mx-auto max-w-[1000px] px-12" data-carousel data-per-view={PER_VIEW}>
    <button
      type="button"
      class="absolute top-1/2 left-0 -translate-y-1/2 text-navy transition-opacity hover:opacity-60"
      aria-label="Vorige logo's"
      data-prev
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 5l-7 7 7 7" />
      </svg>
    </button>

    <div class="overflow-hidden">
      <div class="flex transition-transform duration-300" data-track>
        {images.map((img) => (
          <div class="flex h-[89px] w-1/2 shrink-0 items-center justify-center md:w-1/3 lg:w-1/6">
            {/* Explicit box: `w-auto` collapses to 0 inside a flex item with
                no intrinsic constraint. */}
            <Image
              src={img}
              alt=""
              width={131}
              height={65}
              densities={[1, 2]}
              class="h-[65px] w-[131px] object-contain"
            />
          </div>
        ))}
      </div>
    </div>

    <button
      type="button"
      class="absolute top-1/2 right-0 -translate-y-1/2 text-navy transition-opacity hover:opacity-60"
      aria-label="Volgende logo's"
      data-next
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>
</section>

<script>
  // Brand-logo carousel. Advances ONE logo per arrow click — the original's
  // Splide runs perMove:1 (verified: one click nudges the row a single logo
  // width, not a page of six). The track's own box is perView slides wide
  // (its children overflow it), so a percentage translate is relative to that
  // window: one logo = (100 / perView)%, not (100 / total).
  document.querySelectorAll<HTMLElement>('[data-carousel][data-per-view]').forEach((root) => {
    const track = root.querySelector<HTMLElement>('[data-track]');
    if (!track) return;

    const count = track.children.length;
    if (count === 0) return;

    // Logos in view at once, tracking the responsive slide widths in the
    // markup (w-1/2 base, md w-1/3, lg w-1/6). Keep these breakpoints in step.
    const perView = () => (window.innerWidth >= 1140 ? 6 : window.innerWidth >= 768 ? 3 : 2);
    const maxIndex = () => Math.max(0, count - perView());

    let index = 0;
    const render = () => {
      index = Math.min(index, maxIndex());
      track.style.transform = `translateX(-${index * (100 / perView())}%)`;
    };

    // Advance a single logo; wrap once the last full view is reached.
    const go = (delta: number) => {
      const span = maxIndex() + 1;
      index = (index + delta + span) % span;
      render();
    };

    root.querySelector('[data-prev]')?.addEventListener('click', () => go(-1));
    root.querySelector('[data-next]')?.addEventListener('click', () => go(1));
    window.addEventListener('resize', render);
  });
</script>
