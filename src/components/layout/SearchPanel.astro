---
import { search as t, a11y } from '../../i18n/nl';

// A floating search panel opened by the header magnifier (`[data-search-open]`).
// It reproduces the original's HubSpot site-search popup — real results, each a
// page title + excerpt linking to the actual page — but on a fully static,
// build-time index (Pagefind, wired in astro.config via astro-pagefind).
//
// We deliberately DON'T use Pagefind's prebuilt <pagefind-searchbox> UI; this
// panel uses Pagefind's JS API directly so the markup carries the site's own
// tokens (navy text, orange <mark> highlights, the theme card + shadow). The
// index (`/pagefind/pagefind.js`) is emitted into dist/ at build time, so the
// import is resolved at runtime in the browser, never bundled.
---

<div
  data-search-overlay
  class="fixed inset-0 z-[100] hidden px-4 pt-[12vh]"
  role="dialog"
  aria-modal="true"
  aria-label={a11y.openSearch}
>
  {/* backdrop */}
  <div class="absolute inset-0 bg-navy/40 backdrop-blur-sm" data-search-backdrop></div>

  {/* panel */}
  <div class="relative mx-auto flex max-h-[76vh] w-full max-w-[640px] flex-col overflow-hidden rounded-2xl bg-white shadow-[0_32px_64px_0_rgba(17,65,122,0.18),0_16px_32px_0_rgba(17,65,122,0.12)]">
    <div class="flex items-center gap-3 border-b border-navy/10 px-5 py-4">
      <svg class="size-5 shrink-0 text-navy/60" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
        <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
      <input
        type="text"
        data-search-input
        placeholder={t.placeholder}
        autocomplete="off"
        class="min-w-0 flex-1 bg-transparent font-body text-[16px] text-navy placeholder:text-navy/40 focus:outline-none"
      />
      <button
        type="button"
        data-search-close
        aria-label={a11y.closeSearch}
        class="shrink-0 text-navy/60 transition-opacity hover:opacity-60"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>

    {/* status line (hint / empty state) */}
    <p data-search-status class="px-5 py-6 text-center font-body text-[14px] text-navy/50">
      {t.hint}
    </p>

    {/* results */}
    <ul data-search-results class="hidden overflow-y-auto px-2 py-2"></ul>

    {/* load more */}
    <div class="hidden border-t border-navy/10 p-3" data-search-more-wrap>
      <button
        type="button"
        data-search-more
        class="mx-auto block rounded-[10px] px-4 py-2 font-body text-[14px] font-medium text-orange transition-colors hover:bg-mist"
      >
        {t.more}
      </button>
    </div>
  </div>
</div>

<style>
  /* Pagefind returns excerpts with <mark> around the matched terms. */
  [data-search-results] :global(mark) {
    background: transparent;
    color: var(--color-orange, #ff6b00);
    font-weight: 600;
  }
</style>

<script>
  import { search as t } from '../../i18n/nl';

  const overlay = document.querySelector<HTMLElement>('[data-search-overlay]');
  const input = document.querySelector<HTMLInputElement>('[data-search-input]');
  const status = document.querySelector<HTMLElement>('[data-search-status]');
  const list = document.querySelector<HTMLUListElement>('[data-search-results]');
  const moreWrap = document.querySelector<HTMLElement>('[data-search-more-wrap]');
  const moreBtn = document.querySelector<HTMLButtonElement>('[data-search-more]');

  if (overlay && input && status && list && moreWrap && moreBtn) {
    const PAGE = 5;
    let pagefindPromise: Promise<any> | null = null;
    let lastFocused: Element | null = null;
    let current: any[] = []; // the full result set for the active query
    let shown = 0;
    let queryId = 0; // monotonic id so a slow search can't overwrite a newer one
    let debounceTimer: ReturnType<typeof setTimeout> | undefined;

    // Load the runtime index on first use, memoised so import() and options()
    // run exactly once — calling them twice concurrently makes the first
    // search get superseded (returns null) on a cold start. The path is
    // resolved in the browser (the file only exists in the built output), so
    // keep Vite out of it.
    function loadPagefind(): Promise<any> {
      if (!pagefindPromise) {
        pagefindPromise = (async () => {
          // Pagefind's runtime lives in the BUILT output (dist/pagefind/), not
          // in the source graph, so Vite must not touch this import. Neither
          // @vite-ignore nor a runtime path stops it wrapping the import in
          // __vitePreload, which then rejects (the path is not a known chunk)
          // and leaves search silently empty. `new Function` hides the import
          // from the bundler entirely — a raw dynamic import at runtime.
          const importPagefind = new Function('u', 'return import(u)');
          const pf = await importPagefind(`${location.origin}/pagefind/pagefind.js`);
          await pf.options?.({ excerptLength: 24 });
          return pf;
        })().catch(() => null);
      }
      return pagefindPromise;
    }

    function open() {
      lastFocused = document.activeElement;
      overlay!.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      loadPagefind();
      input!.focus();
    }

    function close() {
      overlay!.classList.add('hidden');
      document.body.style.overflow = '';
      if (lastFocused instanceof HTMLElement) lastFocused.focus();
    }

    function setStatus(msg: string | null) {
      if (msg) {
        status!.textContent = msg;
        status!.classList.remove('hidden');
      } else {
        status!.classList.add('hidden');
      }
    }

    async function renderMore() {
      const slice = current.slice(shown, shown + PAGE);
      const data = await Promise.all(slice.map((r) => r.data()));
      for (const d of data) {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = d.url;
        a.className =
          'block rounded-xl px-3 py-3 transition-colors hover:bg-mist focus:bg-mist focus:outline-none';
        const title = document.createElement('span');
        title.className = 'block font-display text-[16px] font-bold text-navy';
        title.textContent = d.meta?.title ?? d.url;
        const ex = document.createElement('span');
        ex.className = 'mt-1 block font-body text-[14px] leading-[20px] text-navy/70';
        ex.innerHTML = d.excerpt ?? '';
        a.append(title, ex);
        li.append(a);
        list!.append(li);
      }
      shown += slice.length;
      moreWrap!.classList.toggle('hidden', shown >= current.length);
    }

    async function run(term: string) {
      const myId = ++queryId;
      list!.innerHTML = '';
      shown = 0;
      moreWrap!.classList.add('hidden');
      list!.classList.add('hidden');

      if (!term.trim()) {
        setStatus(t.hint);
        return;
      }

      const pf = await loadPagefind();
      if (myId !== queryId) return; // a newer keystroke superseded this one
      if (!pf) {
        // Index not built yet (e.g. dev before a build) — fail gracefully.
        setStatus(t.empty);
        return;
      }

      // Plain search(), not debouncedSearch(): the latter returns null on its
      // first cold call before the index self-initialises. We debounce the
      // keystrokes ourselves and drop stale responses via queryId.
      const res = await pf.search(term);
      if (myId !== queryId) return; // superseded while the search ran
      current = res?.results ?? [];

      if (current.length === 0) {
        setStatus(t.empty);
        return;
      }
      setStatus(null);
      list!.classList.remove('hidden');
      await renderMore();
    }

    // triggers
    document.querySelectorAll('[data-search-open]').forEach((btn) =>
      btn.addEventListener('click', open),
    );
    document.querySelector('[data-search-close]')?.addEventListener('click', close);
    document.querySelector('[data-search-backdrop]')?.addEventListener('click', close);
    moreBtn.addEventListener('click', renderMore);
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const term = input.value;
      debounceTimer = setTimeout(() => run(term), 180);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay!.classList.contains('hidden')) close();
    });
  }
</script>
