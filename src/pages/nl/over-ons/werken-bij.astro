---
import Base from '../../../layouts/Base.astro';
import { Image } from 'astro:assets';
import PhotoCarousel from '../../../components/ui/PhotoCarousel.astro';
import ValueCard from '../../../components/ui/ValueCard.astro';
import TestimonialCard from '../../../components/ui/TestimonialCard.astro';
import evanPhoto from '../../../assets/colleague-evan.jpg';
import eefjePhoto from '../../../assets/colleague-eefje.jpg';
// Kevin's card uses Koen.jpg on the original (its alt is "Koen"); that asset was
// already fetched for the over-ons quote, so it is reused rather than re-downloaded.
import kevinPhoto from '../../../assets/icons/koen-1xlcx.jpg';
import { resolveIcon } from '../../../lib/icons';
import { bandFor } from '../../../lib/bands';
import { valueIcons } from '../../../lib/valueIcons';
import page from '../../../i18n/pages/nl-over-ons-werken-bij.json';

// "Werken bij Jobmatix" — linked from the main nav on EVERY page, so its
// absence was a broken link on all 48 routes rather than a missing extra.
// Two-segment path, which is why it needs its own route rather than joining
// the /nl/[slug] landing template.
//
// Structure on the original (top → bottom): hero (navy band — heading + intro)
// → the open vacancy card → "Onze kernwaarden" (intro + three value cards) →
// "Kantoormomenten" (office photo gallery) → colleague testimonials. That is the
// end of the page — the original has NO closing CTA and NO form (only the header
// site-search). An earlier version rendered a ContactCta (FormStub) below the
// testimonials, which added a form the original never had AND duplicated the
// "Wat zeggen onze collega's?" heading (ctaHeading resolves to the last heading
// module); it also stranded the hero's intro line — "Voeg je bij ons team…" —
// on that CTA instead of under the hero. Both the intro and kernwaarden intro
// live in the page JSON now (mirroring over-ons.astro).
//
// The value cards use ValueCard (navy fill + circular icon disc), and the three
// colleague testimonials are restored below (the extractor captures no review
// data, so their copy is inlined verbatim — see the block above them).

const title = page.hero.title || page.headings[0] || 'Werken bij Jobmatix';

const heading = (prefix: string) =>
  page.blocks?.find((b: any) => b.heading?.toLowerCase().startsWith(prefix.toLowerCase()))?.heading ??
  null;
const block = (prefix: string) =>
  page.blocks?.find((b: any) => b.heading?.toLowerCase().startsWith(prefix.toLowerCase())) ?? null;

// Hero intro — the "Voeg je bij ons team…" line the original places directly
// under the hero heading, on the same navy band (content_bucket-row-0).
const heroIntro = block('Bouw mee aan succes')?.body?.[0] ?? null;

const valuesHeading = heading('Onze kernwaarden');
// Intro paragraph under the "Onze kernwaarden" heading, above the value cards —
// same pattern as over-ons.astro's kernwaardenIntro.
const kernwaardenIntro = block('Onze kernwaarden')?.body?.[0] ?? null;
const values = (page.featureCards ?? []).filter((c) => c.title);
// The value-card glyphs are shared with /nl/over-ons (see lib/valueIcons).

// Colleague testimonials under "Wat zeggen onze collega's?". The extractor has
// no review data yet (see FINDINGS / the header comment), so the three quotes,
// names and roles are restored here byte-for-byte from the original — including
// its curly quotation marks. Photos are local assets.
const testimonialsHeading = heading("Wat zeggen onze collega");
const testimonials = [
  {
    quote:
      '“Echt heel gaaf om onderdeel te zijn van een organisatie die met de week groeit. Je ziet klanten echt glunderen als ze een demo van ons krijgen. Fijn om zo van toegevoegde waarde te zijn.”',
    name: 'Evan',
    role: 'Recruitment Marketeer',
    photo: evanPhoto,
  },
  {
    quote:
      '“Wat werken bij Jobmatix leuk maakt is het hechte team dat altijd voor elkaar klaarstaat. Daarnaast vind ik het heel gaaf dat onze klanten heel blij zijn met onze kennis en tool.”',
    name: 'Eefje',
    role: 'Recruitment Marketeer',
    photo: eefjePhoto,
  },
  {
    quote:
      '“Samen met het technisch team werken aan het onderhouden en doorontwikkelen van de Jobmatix tool is het mooiste wat er is. Ik krijg alle ruimte om mezelf te ontwikkelen en keuzes te maken.”',
    name: 'Kevin',
    role: 'Developer',
    photo: kevinPhoto,
  },
];

const kantoorHeading = heading('Kantoormomenten');
// The scrape captured Splide's loop CLONES too, so contentImages holds 21
// entries for 9 real photos (3× each for the cloned ones). Dedupe by src,
// keeping first-appearance order — which matches the original's slide order.
const seenKantoor = new Set<string>();
const gallery = (page.contentImages ?? [])
  .filter((i: any) => i.afterHeading === kantoorHeading)
  .filter((i: any) => (seenKantoor.has(i.src) ? false : (seenKantoor.add(i.src), true)))
  .map((i: any) => ({ ...i, resolved: resolveIcon(i.src) }))
  .filter((i: any) => i.resolved);

// The open-vacancy card the original shows under the hero.
const vacancy = page.contactCards?.[0] ?? null;
const vacancyImg = resolveIcon(vacancy?.image);
const vacancyLink = (vacancy?.links ?? []).find((l: any) => l.href)?.href ?? null;
---

<Base title={page.meta.title} description={page.meta.description ?? undefined}>
  {/* Hero — navy band (content_bucket-row-0), 70px vertical padding, centred
      white text. CompactHero renders a title only and can't hold the intro, so
      the band is inlined here to keep the heading and its intro on the SAME navy
      block, exactly as the original places "Voeg je bij ons team…" under the
      heading. */}
  <section class="bg-navy px-6 py-[70px] text-center text-white">
    <div class="container-site">
      <h1 class="font-display text-[40px] leading-[44px] font-bold text-white">{title}</h1>
      {heroIntro && (
        <p class="mx-auto mt-4 max-w-[820px] text-[16px] leading-[26px] text-white">{heroIntro}</p>
      )}
    </div>
  </section>

  {/* Open vacancy card. */}
  {vacancy && (
    <section class="px-6 py-12">
      <div class="mx-auto flex max-w-[900px] flex-col items-center gap-6 rounded-3xl bg-white p-6 shadow-card md:flex-row md:p-8">
        {vacancyImg && (
          <Image src={vacancyImg} alt="" width={384} height={192} class="h-auto w-full rounded-2xl object-cover md:w-[300px] md:shrink-0" />
        )}
        <div class="flex-1">
          {vacancy.title && (
            <h2 class="font-display text-[24px] leading-[30px] font-bold text-navy">{vacancy.title}</h2>
          )}
          {vacancy.body && <p class="mt-3 text-[16px] leading-[24px] text-navy/80">{vacancy.body}</p>}
          {vacancyLink && (
            <a
              href={vacancyLink}
              class="mt-5 inline-flex h-[48px] items-center rounded-[12px] bg-orange px-6 text-[16px] font-medium text-white transition-opacity hover:opacity-90"
            >
              Bekijk vacature
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  {/* "Onze kernwaarden" — three value cards. */}
  {values.length > 0 && (
    <section class="px-6 py-14" style={`background-color:${bandFor(page, 'Onze kernwaarden') ?? '#f5f5ff'}`}>
      <div class="mx-auto max-w-[1138px]">
        {valuesHeading && (
          <h2 class="text-center font-display text-[30px] leading-[33px] font-bold text-navy">
            {valuesHeading}
          </h2>
        )}
        {kernwaardenIntro && (
          <p class="mx-auto mt-4 max-w-[820px] text-center text-[16px] leading-[26px] text-navy">
            {kernwaardenIntro}
          </p>
        )}
        <div class="mt-11 flex flex-wrap justify-center gap-y-6 -mx-3">
          {values.map((v) => (
            <div class="w-full px-3 md:w-1/2 lg:w-1/3">
              <ValueCard title={v.title} body={v.body} iconSvg={valueIcons[v.title]} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* "Kantoormomenten" — office photo carousel (Splide replica). */}
  {gallery.length > 0 && (
    <section class="px-6 py-14">
      {kantoorHeading && (
        <h2 class="mb-10 text-center font-display text-[30px] leading-[33px] font-bold text-navy">
          {kantoorHeading}
        </h2>
      )}
      <PhotoCarousel images={gallery} />
    </section>
  )}

  {/* "Wat zeggen onze collega's?" — three boxed colleague testimonials. Static
      grid on the original (3-up desktop, 2-up tablet), not a carousel. */}
  <section class="px-6 py-14">
    {testimonialsHeading && (
      <h2 class="mb-10 text-center font-display text-[30px] leading-[33px] font-bold text-navy">
        {testimonialsHeading}
      </h2>
    )}
    <div class="mx-auto flex max-w-[1138px] flex-wrap justify-center -mx-3">
      {testimonials.map((t) => (
        <div class="w-full px-3 md:w-1/2 lg:w-1/3">
          <TestimonialCard quote={t.quote} name={t.name} role={t.role} photo={t.photo} />
        </div>
      ))}
    </div>
  </section>
</Base>
