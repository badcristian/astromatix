---
import Base from '../../layouts/Base.astro';
import GoCard from '../../components/ui/GoCard.astro';
import Button from '../../components/ui/Button.astro';
import Reveal from '../../components/ui/Reveal.astro';
import ReviewCarousel from '../../components/sections/ReviewCarousel.astro';
import { resolveIcon } from '../../lib/icons';
import page from '../../i18n/pages/nl-klantcases.json';
import { bandFor } from '../../lib/bands';

// The original ships no <h1> here (as on jobboost, over-ons and contact); we
// render one. It fuses the hero title and its supporting line into one
// <br>-separated <h2>, which the extractor flattens — split it back.
const heroRaw = page.headings.find((h) => h.startsWith('Samen succesvol')) ?? '';
const [heroTitle, heroSubtitle] = (() => {
  const i = heroRaw.indexOf('Bekijk');
  return i > 0
    ? [heroRaw.slice(0, i).trim(), heroRaw.slice(i).trim()]
    : [heroRaw || 'Klantcases', null];
})();
const cards = (page.goCards ?? []).map((c) => ({ ...c, img: resolveIcon(c.image) }));

// The "Benieuwd hoe jij…" section is a navy CTA with a BUTTON and NO form
// (unlike the shared ContactCta). Its button is "Plan een gesprek!".
const ctaTitle =
  page.blocks.find((b: any) => b.heading?.startsWith('Benieuwd hoe jij'))?.heading ??
  'Benieuwd hoe jij jouw job marketing eenvoudig vanuit één plek kunt regelen?';
const ctaButton =
  page.buttons.find((b) => /gesprek/i.test(b.label)) ?? page.buttons.at(-1) ?? null;

// Two case studies are linked at doubled /nl/nl/ paths — migration artifacts.
// We serve them at the clean /nl/actueel/klantcase/ path.
const cleanHref = (href: string | null | undefined) =>
  (href ?? '#')
    .replace('/nl/nl/actueel/klantcase/', '/nl/actueel/klantcase/')
    .replace('/nl/nl/klantcase/', '/nl/actueel/klantcase/');

const tevredenHeading = page.headings.find((h) => h.startsWith('Tevreden')) ?? null;
const reviewsBand = bandFor(page, 'Tevreden') ?? '#f5f5ff';
---

<Base title={page.meta.title} description={page.meta.description ?? undefined}>
  {/* Compact navy hero — the heading sits ~50px below the header, not the tall
      200px PageHero. */}
  <section class="bg-navy px-6 pt-[50px] pb-[50px] text-center text-white">
    <div class="container-site">
      <h1 class="font-display text-[40px] leading-[48px] font-bold text-white">{heroTitle}</h1>
      {heroSubtitle && (
        <p class="mx-auto mt-3 max-w-[760px] text-[16px] leading-[24px] text-white/90">{heroSubtitle}</p>
      )}
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto max-w-[1138px]">
      <Reveal variant="zoom" duration={500} class="flex flex-wrap -mx-3">
        {cards.map((card) => card.img && (
          <div class="w-full px-3 md:w-1/3">
            <GoCard image={card.img} name={card.name} title={card.title} href={cleanHref(card.href)} />
          </div>
        ))}
      </Reveal>
    </div>
  </section>

  {/* Navy CTA: heading + button, NO form. */}
  <section class="bg-navy px-6 py-14">
    <div class="mx-auto flex max-w-[1200px] flex-col items-center gap-6 text-center lg:flex-row lg:justify-between lg:text-left">
      <h2 class="font-display text-[30px] leading-[38px] font-bold text-white">{ctaTitle}</h2>
      {ctaButton && <Button href={ctaButton.href} label={ctaButton.label} />}
    </div>
  </section>

  {/* "Tevreden klanten" — a review carousel on #f5f5ff, not a logo wall. */}
  {tevredenHeading && (
    <section class="px-6 pt-16" style={`background-color:${reviewsBand}`}>
      <h2 class="text-center font-display text-[30px] leading-[33px] font-bold text-navy">
        {tevredenHeading}
      </h2>
    </section>
  )}
  <div style={`background-color:${reviewsBand}`}>
    <ReviewCarousel reviews={page.reviews ?? []} />
  </div>
</Base>
