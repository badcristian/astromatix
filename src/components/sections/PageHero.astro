---
import { resolveIcon } from '../../lib/icons';
// Interior-page hero. Measured on /nl/oplossingen/jobadvertising @1440:
//   section 1440×552, navy, padding 100px 24px 0
//   h1      Poppins 700, white, centred
//   sub     centred beneath it
//
// Product and marketing pages share this; the homepage keeps its own Hero,
// which has a different rhythm and its own CTA.
//
// WHY THIS ALWAYS RENDERS AN <h1>
// Four of the original's nine pages ship no <h1> at all — jobboost, over-ons,
// contact and klantcases open straight into an <h2>. That is an accessibility
// failure (WCAG 1.3.1: screen-reader users navigate by heading, and there is
// no top-level landmark to jump to) and a lost SEO signal (Google falls back
// to <title> and body copy, but the clearest statement of what a page is about
// is absent from its own markup).
//
// The fix is free: on those pages the top <h2> IS the page title in everything
// but tag name, so promoting it changes one character of HTML and nothing
// visually. Rendering it here means every page that uses PageHero gets exactly
// one <h1>, and no page can regress by omission.
//
// Deliberate divergence from the original — see FINDINGS.md.

interface Props {
  title: string;
  subtitle?: string | null;
  cta?: { label: string; href: string } | null;
  /**
   * Hero background photo, as a remote URL from the extractor's hero.background.
   *
   * Fourteen pages carry one and none of them rendered it — every hero was a
   * flat navy band. The extractor missed them because the image sits on an
   * ANCESTOR row rather than the element nearest the <h1>; once that was fixed
   * the URLs appeared for klantcase, vacature, jobadvertising and four landing
   * pages at once.
   *
   * Navy stays underneath as the fallback, which is also what keeps the white
   * heading legible while the photo loads.
   */
  background?: string | null;
  /**
   * Band colour behind the hero, as a resolved CSS colour from the extractor.
   *
   * Navy on most pages but INK (#111d29) on /veel-gestelde-vragen — hard-coding
   * bg-navy shipped the wrong colour there. See src/lib/bands.ts.
   */
  band?: string | null;
}

const { title, subtitle, cta, background = null, band = null } = Astro.props;
const bg = resolveIcon(background);
---

{/* h1 sits 200px below the section top on the original (section padding
    is 100, with another 100 inside), not the 100 first assumed. */}
<section
  class="bg-navy bg-cover bg-center px-6 pt-[200px] pb-[60px] text-center text-white"
  style={[
    band ? `background-color:${band}` : '',
    bg ? `background-image:url(${bg.src})` : '',
  ].filter(Boolean).join(';') || undefined}
>
  <div class="container-site">
    <h1 class="font-display text-[40px] leading-[52px] font-bold text-white">
      {title}
    </h1>

    {subtitle && (
      <p class="mx-auto mt-6 max-w-[760px] text-[16px] leading-[24px] text-white">
        {subtitle}
      </p>
    )}

    {cta && (
      <a
        href={cta.href}
        class="mt-8 inline-flex h-[52px] items-center rounded-[12px] bg-orange px-[21.76px] text-[16px] font-medium text-white transition-opacity hover:opacity-90"
      >
        {cta.label}
      </a>
    )}
  </div>
</section>
