---
import Base from '../../../layouts/Base.astro';
import ProductHero from '../../../components/sections/ProductHero.astro';
import FeatureBand from '../../../components/sections/FeatureBand.astro';
import FeatureCard from '../../../components/ui/FeatureCard.astro';
import Accordion from '../../../components/ui/Accordion.astro';
import ContactCta from '../../../components/sections/ContactCta.astro';
import Reveal from '../../../components/ui/Reveal.astro';
import QuickFeat from '../../../components/ui/QuickFeat.astro';
import CtaStrip from '../../../components/sections/CtaStrip.astro';
import PricingTier from '../../../components/ui/PricingTier.astro';
import { Image } from 'astro:assets';
import { resolveIcon } from '../../../lib/icons';
import page from '../../../i18n/pages/nl-oplossingen-jobboost.json';
import { bandFor, heroBand } from '../../../lib/bands';


// Shares jobadvertising's shape but without the featshow and steps modules.
//
// The original ships NO <h1> on this page: it opens straight into an <h2>.
// We render one, because inheriting an SEO and accessibility defect into a
// rebuild pitched as an improvement would be the wrong call.
const bandIcons = ['download', 'expand', 'send', 'arrow'] as const;
const band = page.properties.map((p, i) => ({ icon: bandIcons[i], label: p.label }));


// The hero CTA is "Kies jouw boost!" and scrolls to the pricing tiers (the
// original links to a cross-page #Prijzenjobboost anchor) — not a redirect.
const kiesBtn = page.buttons.find((b) => /Kies jouw boost/i.test(b.label));
const heroCta = kiesBtn ? { label: kiesBtn.label, href: '#prijzen' } : null;
const stripCta = page.buttons.find((b) => /Plan een gesprek/i.test(b.label)) ?? null;

// Headings by content, not index — see the note in jobadvertising.astro. The
// extractor's visibility filter shortened this page's heading list from 8 to 6
// and every index below shifted, which is invisible at build time: a wrong
// index renders another section's sentence, and an out-of-range one renders
// nothing at all.
const heading = (prefix: string) =>
  page.headings.find((h) => h.toLowerCase().startsWith(prefix.toLowerCase())) ?? null;
const block = (prefix: string) =>
  page.blocks?.find((b: any) => b.heading?.toLowerCase().startsWith(prefix.toLowerCase())) ?? null;

const heroSubtitle = heading('Boost jouw vacature');
// The original hard-breaks this h2 after "en" — two lines, same visible copy.
const heroSubtitleHtml = heroSubtitle?.replace(/\ben\s+vergroot/, 'en <br>vergroot') ?? null;
const chooseHeading = heading('Kies jouw Jobboost en bereik');
// The original hard-breaks this heading after "bereik" and sets it in Manrope
// at 30/33 (not Poppins at 30/52.5 like the cards heading we copied from
// jobadvertising) — so it reads tighter and a touch smaller. Same visible copy.
const chooseHeadingHtml = chooseHeading?.replace('bereik jouw', 'bereik <br>jouw') ?? '';
// A centred 18px intro sits under that heading on the original — it was dropped
// because we only read the heading string, never the block's body.
const chooseIntro = block('Kies jouw Jobboost en bereik')?.body?.[0] ?? null;
const tiersHeading = heading('Kies jouw Jobboost!');
const stripHeading = block('Benieuwd hoe jij jouw job marketing')?.heading ?? null;
const faqHeading = heading('Veelgestelde vragen');
const ctaHeading = heading('Klaar om jouw vacature');

// A 588px-wide dashboard illustration sits beside the FAQ on both product
// pages. It carries NO module class, so no module-based extractor could see it
// and it was simply absent — worth ~650px here and ~250px on jobboost. Found
// by contentImages, which anchors on the nearest preceding heading.
const faqImage = (() => {
  const hit = (page.contentImages ?? []).find(
    (i: any) => i.afterHeading?.startsWith('Veelgestelde vragen') && i.width > 300,
  );
  const resolved = resolveIcon(hit?.src);
  return resolved ? { ...hit, resolved } : null;
})();
---

<Base title={page.meta.title} description={page.meta.description ?? undefined}>
  {/* Light hero, navy title on the LEFT, with "Home (5).png" as a
      bottom-centre backdrop (the original's background-position 50% 100%). */}
  <ProductHero
    title={page.hero.title}
    subtitle={heroSubtitle}
    subtitleHtml={heroSubtitleHtml}
    cta={heroCta ? { label: heroCta.label, href: heroCta.href } : null}
    image={resolveIcon(page.hero.background)}
    theme="light"
    imageAsBackdrop
  />

  <FeatureBand items={band} chip={false} />

  <section class="px-6 pt-[70px] pb-[20px]">
    <div class="mx-auto max-w-[1200px]">
      <h2 class="mx-auto max-w-[1050px] text-center font-sans text-[30px] leading-[33px] font-bold text-navy">
        <Fragment set:html={chooseHeadingHtml} />
      </h2>

      {chooseIntro && (
        <p class="mx-auto mt-6 max-w-[1050px] text-center text-[18px] leading-[25.2px] text-navy">
          {chooseIntro}
        </p>
      )}

      <Reveal variant="zoom" duration={1000} class="mt-11 flex flex-wrap justify-center -mx-3">
        {page.featureCards.map((card, i) => (
          <div class="w-full px-3 md:w-1/2 lg:w-1/3">
            <FeatureCard icon={resolveIcon(card.icon)} title={card.title} body={card.body} />
          </div>
        ))}
      </Reveal>
    </div>
  </section>

  {page.pricing && (
    <section id="prijzen" class="scroll-mt-[90px] px-6 py-[70px]">
      <div class="mx-auto max-w-[1200px]">
        <h2 class="text-center font-display text-[30px] leading-[33px] font-bold text-navy">
          {tiersHeading}
        </h2>
        <Reveal variant="zoom" duration={1000} class="mt-11 flex flex-wrap justify-center -mx-3">
          {page.pricing.map((tier) => (
            <div class="mb-6 w-full px-3 md:w-1/2 lg:w-1/3">
              <PricingTier {...tier} />
            </div>
          ))}
        </Reveal>
      </div>
    </section>
  )}

  {/* The CtaStrip ("Benieuwd hoe…") sits ABOVE the quickfeat on the original. */}
  {stripCta && stripHeading && <CtaStrip heading={stripHeading} cta={stripCta} />}

  {page.quickfeat && (
    <section class="bg-mist px-6 py-24">
      <div class="mx-auto max-w-[1138px]">
        <QuickFeat items={page.quickfeat} />
      </div>
    </section>
  )}

  {/* Image LEFT, heading + accordion RIGHT — the accordion is a white card
      with the theme shadow, on a white section (same as jobadvertising). */}
  <section class="bg-white px-6 py-[60px]">
    <div class="mx-auto flex max-w-[1200px] flex-col items-center gap-10 lg:flex-row lg:gap-20">
      {faqImage && (
        <Image
          src={faqImage.resolved}
          alt=""
          width={faqImage.width}
          height={faqImage.height}
          class="h-auto w-full rounded-3xl lg:w-[588px] lg:shrink-0"
        />
      )}
      <div class="lg:flex-1">
        <h2 class="mb-6 font-display text-[30px] leading-[33px] font-bold text-navy">
          {faqHeading}
        </h2>
        <Accordion items={page.accordion} />
      </div>
    </div>
  </section>

  {/* jobboost's own form carries the "Welke boost past bij jou?" checkbox
      group (Small / Medium / Large) that the shared form lacks. */}
  <ContactCta
    title={ctaHeading!}
    intro={null}
    band={bandFor(page, "Klaar om jouw")}
    id="Contactjobboost"
    fields={page.forms?.[0]?.fields ?? undefined}
    submitLabel={page.forms?.[0]?.submitLabel ?? undefined}
  />
</Base>
