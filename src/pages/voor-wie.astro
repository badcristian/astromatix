---
import Base from '../layouts/Base.astro';
import PageHero from '../components/sections/PageHero.astro';
import PropertyItem from '../components/ui/PropertyItem.astro';
import Reveal from '../components/ui/Reveal.astro';
import { Image } from 'astro:assets';
import { resolveIcon } from '../lib/icons';
import page from '../i18n/pages/voor-wie.json';

// Four audience sections, each 660px on the original: an image-box beside a
// heading and a three-item property list, with the image side alternating.
// The first build rendered only the property lists, which left the page 1344
// short — the image-box half was missing entirely.
const icons = ['download', 'expand', 'send', 'arrow'] as const;
const blocks = (page.audienceBlocks ?? []).map((b) => ({ ...b, img: resolveIcon(b.image) }));

// No ContactCta on this page. The original /voor-wie carries no form and no
// closing CTA section at all — it ends at the fourth audience block. Appending
// the shared strip added a form the page does not have.
---

<Base title={page.meta.title} description={page.meta.description ?? undefined}>
  <PageHero title={page.hero.title} subtitle={page.headings[0] ?? null} />

  {blocks.map((block, i) => (
    <section class:list={['px-6 py-[75px]', i % 2 === 1 && 'bg-mist']}>
      <Reveal
        variant={block.imageRight ? 'right' : 'left'}
        duration={1000}
        class:list={[
          'mx-auto flex max-w-[1200px] flex-col gap-10 lg:flex-row lg:items-center lg:gap-20',
          block.imageRight && 'lg:flex-row-reverse',
        ]}
      >
        {block.img && (
          <div class="lg:w-[510px] lg:shrink-0">
            <Image src={block.img} alt="" width={510} densities={[1, 2]} class="w-full rounded-3xl" />
          </div>
        )}

        <div class="lg:flex-1">
          <h2 class="font-display text-[30px] leading-[38px] font-bold text-navy">
            {block.title}
          </h2>
          {block.body && (
            <p class="mt-4 text-[16px] leading-[24px] text-navy">{block.body}</p>
          )}
          <div class="mt-6 flex flex-col gap-4">
            {block.properties.map((prop, j) => (
              <PropertyItem icon={icons[j % 4]} label={prop.label} variant="dark" />
            ))}
          </div>
        </div>
      </Reveal>
    </section>
  ))}

</Base>
