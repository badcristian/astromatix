---
import { Image } from 'astro:assets';
import { resolveIcon } from '../../lib/icons';

// The klantcases "Tevreden klanten" `.module--review` carousel: customer
// reviews, one per slide — avatar, quote, name, company — with prev/next
// arrows and pagination dots. A small translateX carousel rather than Splide,
// matching TestimonialCarousel, to avoid a runtime dependency.

interface Props {
  reviews: {
    quote: string | null;
    name: string | null;
    company: string | null;
    avatar: string | null;
  }[];
}

const { reviews } = Astro.props;
const slides = reviews
  .map((r) => ({ ...r, img: resolveIcon(r.avatar) }))
  .filter((r) => r.quote);
---

{slides.length > 0 && (
  <section class="px-6 pb-16">
    <div class="relative mx-auto max-w-[850px] px-12" data-review-carousel>
      <button
        type="button"
        class="absolute top-1/2 left-0 -translate-y-1/2 text-navy transition-opacity hover:opacity-60"
        aria-label="Vorige"
        data-prev
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 5l-7 7 7 7" />
        </svg>
      </button>

      <div class="overflow-hidden">
        <div class="flex transition-transform duration-300" data-track>
          {slides.map((r) => (
            <figure class="w-full shrink-0 px-6 text-center">
              {r.img && (
                <Image src={r.img} alt="" width={80} height={80} class="mx-auto size-20 rounded-full object-cover" />
              )}
              <blockquote class="mx-auto mt-6 max-w-[706px] text-[16px] leading-[22.4px] text-navy">
                {r.quote}
              </blockquote>
              {r.name && (
                <figcaption class="mt-4 font-display text-[16px] font-bold text-navy">
                  {r.name}
                  {r.company && <span class="block font-body font-normal text-navy/60">{r.company}</span>}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      </div>

      <button
        type="button"
        class="absolute top-1/2 right-0 -translate-y-1/2 text-navy transition-opacity hover:opacity-60"
        aria-label="Volgende"
        data-next
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <div class="mt-6 flex justify-center gap-2" data-dots>
        {slides.map((_, i) => (
          <button
            type="button"
            class="size-2 rounded-full bg-navy/20 transition-colors aria-[current=true]:bg-navy"
            aria-label={`Review ${i + 1}`}
            aria-current={i === 0 ? 'true' : 'false'}
            data-dot={i}
          />
        ))}
      </div>
    </div>
  </section>
)}

<script>
  document.querySelectorAll<HTMLElement>('[data-review-carousel]').forEach((root) => {
    const track = root.querySelector<HTMLElement>('[data-track]');
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-dot]'));
    const count = dots.length;
    let index = 0;

    const go = (next: number) => {
      index = (next + count) % count;
      if (track) track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((d, i) => d.setAttribute('aria-current', String(i === index)));
    };

    root.querySelector('[data-prev]')?.addEventListener('click', () => go(index - 1));
    root.querySelector('[data-next]')?.addEventListener('click', () => go(index + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));
  });
</script>
