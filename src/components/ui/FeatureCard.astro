---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// The original's `.feature-card`. Measured @1440:
//   card    384 wide, padding 24, radius 24, bg rgba(255,255,255,0.05),
//           shadow rgba(17,65,122,0.05) 0 16px 32px, margin-bottom 24
//   body    300 wide, 18px side margins (24 padding + 18 margin = 42 inset)
//   icon    58×58 chip, bg #f5f5ff, radius 10, holding a 29×29 glyph;
//           margin 8.96px 0 24px
//   title   Poppins 700 20px/28px navy, margin-bottom 24
//   desc    16px/22.4px navy, margin-bottom 24
//
// Everything is centred. The 24px rhythm between every element is what drives
// the card's 327px height — worth preserving rather than eyeballing gaps.

// The stats band reuses this card with a solid white background, a narrower
// body, and no side inset — hence the props.

interface Props {
  // Optional: some pages (over-ons, quickfeat) use inline SVG in the theme,
  // so there is no URL for the extractor to find. Falls back to a glyph.
  icon?: ImageMetadata;
  title: string;
  body: string;
  /** translucent = value prop (white/5); white = stats band; navy = over-ons
   * "Onze kernwaarden" cards (navy fill, white text). */
  background?: 'translucent' | 'white' | 'navy';
  /** Horizontal inset on the inner body. 18px on the value prop, 0 on stats. */
  bodyInset?: number;
  /** Heading level — h4 on the value prop, h3 on the stats band. */
  as?: 'h3' | 'h4';
}

const {
  icon,
  title,
  body,
  background = 'translucent',
  bodyInset = 18,
  as: Heading = 'h4',
} = Astro.props;

const navy = background === 'navy';
const textColor = navy ? 'text-white' : 'text-navy';
---

<div
  class:list={[
    // h-full so cards in a flex row stretch to equal height — otherwise a
    // shorter label ("sollicitaties") makes its card shorter than a card whose
    // label wraps to more lines ("tevreden gebruikers").
    'mb-6 h-full rounded-3xl p-6 text-center shadow-[0_16px_32px_0_rgba(17,65,122,0.05)]',
    navy ? 'bg-navy' : background === 'white' ? 'bg-white' : 'bg-white/5',
  ]}
>
  <div style={`margin-inline:${bodyInset}px`}>
    {/* 9px, not the original's 8.96 — the fraction truncates to a 32px offset
        from the card top here, where the original computes 33. */}
    <div class="mt-[9px] mb-6 flex justify-center">
      <span class:list={['inline-flex size-[58px] items-center justify-center rounded-[10px]', navy ? 'bg-white/15 text-white' : 'bg-mist text-navy']}>
        {icon ? (
          <Image src={icon} alt="" width={29} densities={[1, 2]} />
        ) : (
          <svg width="29" height="29" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M8 12l3 3 5-6" />
          </svg>
        )}
      </span>
    </div>

    <Heading class:list={['mb-6 font-display text-[20px] leading-[28px] font-bold', textColor]}>
      {title}
    </Heading>

    <p class:list={['mb-6 text-[16px] leading-[22.4px]', textColor]}>
      {body}
    </p>
  </div>
</div>
