---
// The original's `.featshow` (nav-left variant). Measured @1440 on
// /nl/oplossingen/jobadvertising:
//   wrapper  1200 wide, 514 tall
//   nav      480 wide on the left, inner list 370 wide
//   content  720 wide, white, 24px radius
//   panel    inner wrapper 500 wide
//
// A nav entry on the LEFT swaps the panel on the RIGHT, and pagination dots
// under the panel do the same. Built as buttons with aria-selected so it is
// keyboard-navigable.
//
// RESPONSIVE: tabbed at every width (the original tabs on mobile too — its
// panels all sit at one y). The nav labels stack above the card on mobile and
// act as the tabs. The previous version hid
// non-first panels with `md:hidden` while the JS toggled plain `hidden` — the
// two never corresponded, so clicking a tab hid the open panel and left the
// new one still hidden, i.e. the box went blank. The visibility is now driven
// entirely by a `data-active` attribute plus the scoped rule below, so the
// tab, the dots, and the JS all agree.

interface Props {
  items: { title: string; body: string | null }[];
}

const { items } = Astro.props;
const uid = `featshow-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="mx-auto flex max-w-[1200px] flex-col gap-8 lg:flex-row" data-featshow>
  <div class="lg:w-[480px] lg:shrink-0">
    <ul class="mx-auto flex max-w-[370px] flex-col gap-4" role="tablist">
      {items.map((item, i) => (
        <li>
          <button
            type="button"
            role="tab"
            id={`${uid}-tab-${i}`}
            aria-controls={`${uid}-panel-${i}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            class="w-full text-left font-display text-[20px] leading-[28px] font-bold text-navy/40 transition-colors aria-selected:text-navy"
            data-featshow-tab={i}
          >
            {item.title}
          </button>
        </li>
      ))}
    </ul>
  </div>

  <div class="lg:w-[720px]">
    {/* The right panel is a white card with the theme's soft navy shadow
        (measured on .featshow__content). The nav labels on the left sit on
        the transparent section background, not inside this card. */}
    <div class="rounded-3xl bg-white p-10 shadow-[0_32px_64px_0_rgba(17,65,122,0.05),0_16px_32px_0_rgba(17,65,122,0.05)]">
      {items.map((item, i) => (
        <div
          role="tabpanel"
          id={`${uid}-panel-${i}`}
          aria-labelledby={`${uid}-tab-${i}`}
          class="fs-panel mx-auto max-w-[500px]"
          data-featshow-panel={i}
          data-active={i === 0 ? '' : undefined}
        >
          <h3 class="font-display text-[20px] leading-[28px] font-bold text-navy">
            {item.title}
          </h3>
          {item.body && (
            <p class="mt-4 text-[16px] leading-[22.4px] text-navy">{item.body}</p>
          )}
        </div>
      ))}
    </div>

    {/* Pagination dots — hidden below lg, where the panels stack. */}
    <div class="mt-6 hidden justify-center gap-3 lg:flex" role="tablist" aria-label="Selecteer">
      {items.map((_, i) => (
        <button
          type="button"
          aria-label={`Toon ${i + 1}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          class="size-3 rounded-full bg-navy/20 transition-colors aria-selected:bg-navy"
          data-featshow-dot={i}
        />
      ))}
    </div>
  </div>
</div>

<style>
  /* Only the active panel shows — tabbed at EVERY width, matching the original
     (its featshow panels all sit at the same y on mobile, i.e. one at a time).
     The nav labels on the left are the tabs. */
  .fs-panel { display: none; }
  .fs-panel[data-active] { display: block; }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-featshow]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLElement>('[data-featshow-tab]'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-featshow-dot]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-featshow-panel]'));

    const select = (index: number) => {
      tabs.forEach((t, i) => t.setAttribute('aria-selected', String(i === index)));
      dots.forEach((d, i) => d.setAttribute('aria-selected', String(i === index)));
      panels.forEach((p, i) => {
        if (i === index) p.setAttribute('data-active', '');
        else p.removeAttribute('data-active');
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(i));
      tab.addEventListener('keydown', (event) => {
        const key = (event as KeyboardEvent).key;
        if (key !== 'ArrowRight' && key !== 'ArrowLeft') return;
        event.preventDefault();
        const next = (i + (key === 'ArrowRight' ? 1 : -1) + tabs.length) % tabs.length;
        tabs[next].focus();
        select(next);
      });
    });

    dots.forEach((dot, i) => dot.addEventListener('click', () => select(i)));
  });
</script>
