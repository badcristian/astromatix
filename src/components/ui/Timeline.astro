---
import { Image } from 'astro:assets';
import { resolveIcon } from '../../lib/icons';

// The original's `.module--timeline`. Measured @1440 on /nl/over-ons:
//   module  1200 wide, 2305 tall across 9 items
//   item    1200 wide, ~220 tall, alternating sides of a centre bar
//   box     552 wide (half the track), 24px inner padding
//   badge   date pill above the title
//   title   28px bold, body 14.4px
//   image   151x101 beside the text
//   dot     30x30 on the centre bar
//
// Rendered as an ordered list: it is a chronology, so the numbering is
// meaningful to assistive tech even though it is visually suppressed.

interface Props {
  items: { badge: string | null; title: string | null; body: string | null; image?: string | null }[];
}
const { items } = Astro.props;
---

<ol class="relative mx-auto max-w-[1200px] list-none">
  {/* centre bar */}
  <li aria-hidden="true" class="absolute inset-y-0 left-1/2 hidden w-px -translate-x-1/2 bg-navy/15 lg:block"></li>

  {items.map((item, i) => {
    const img = resolveIcon(item.image);
    const right = i % 2 === 1;
    return (
      <li class="relative mb-10 lg:mb-6">
        <div class:list={['lg:flex', right ? 'lg:justify-end' : 'lg:justify-start']}>
          <div class="rounded-3xl bg-white p-6 shadow-[0_16px_32px_0_rgba(17,65,122,0.05)] lg:w-[552px]">
            {item.badge && (
              <span class="inline-block rounded-full bg-orange px-3 py-1 text-[11.68px] font-bold text-white">
                {item.badge}
              </span>
            )}
            <div class="mt-3 flex gap-6">
              <div class="min-w-0 flex-1">
                {item.title && (
                  <h3 class="font-display text-[28px] leading-[35px] font-bold text-navy">
                    {item.title}
                  </h3>
                )}
                {item.body && (
                  <p class="mt-2 text-[14.4px] leading-[20.16px] text-navy">{item.body}</p>
                )}
              </div>
              {img && (
                <Image src={img} alt="" width={151} height={101} class="h-[101px] w-[151px] shrink-0 rounded-xl object-cover" />
              )}
            </div>
          </div>
        </div>

        {/* dot on the centre bar */}
        <span
          aria-hidden="true"
          class="absolute top-8 left-1/2 hidden size-[30px] -translate-x-1/2 rounded-full border-4 border-white bg-navy lg:block"
        ></span>
      </li>
    );
  })}
</ol>
