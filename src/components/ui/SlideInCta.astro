---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Replica of the original's HubSpot "web-interactive" pop-up: a card that slides
// in from the bottom-right once you scroll into the article, dismissible with an
// X (and it stays dismissed for the session). The original is a cross-origin
// iframe we can't embed; this rebuilds it natively with the same copy + image.
//
// The outer wrapper is a full-width, overflow-clipped, click-through strip so the
// panel can start off-screen right without ever adding a horizontal scrollbar.

interface Props {
  image: ImageMetadata;
  title: string;
  subtitle: string;
  buttonLabel: string;
  buttonHref: string;
}
const { image, title, subtitle, buttonLabel, buttonHref } = Astro.props;
---

<div
  class="slide-cta pointer-events-none fixed inset-x-0 bottom-4 z-50 hidden overflow-hidden px-4"
  data-slide-cta
>
  <div
    class="slide-cta__panel pointer-events-auto relative ml-auto flex w-[min(560px,100%)] overflow-hidden rounded-2xl bg-[#eceefb] shadow-card-lg"
  >
    <button
      type="button"
      class="absolute right-3 top-3 z-10 grid size-8 place-items-center rounded-full text-navy transition-colors hover:bg-navy/10"
      aria-label="Sluiten"
      data-slide-cta-close
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <Image src={image} alt="" width={280} class="hidden w-[40%] shrink-0 self-stretch object-cover sm:block" />

    <div class="flex flex-col justify-center gap-3 p-6">
      <h3 class="font-display text-[24px] leading-[28px] font-bold text-navy">{title}</h3>
      <p class="text-[16px] leading-[22px] text-navy">{subtitle}</p>
      <a
        href={buttonHref}
        class="mt-1 inline-flex h-[48px] w-fit items-center rounded-[10px] bg-orange px-6 text-[16px] font-medium text-white transition-opacity hover:opacity-90"
      >
        {buttonLabel}
      </a>
    </div>
  </div>
</div>

<style>
  /* The panel starts off-screen to the right; the wrapper clips it so there is
     no horizontal overflow. `[data-open]` slides it in. */
  .slide-cta__panel {
    transform: translateX(calc(100% + 1.5rem));
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.4s ease;
  }
  .slide-cta[data-open] .slide-cta__panel {
    transform: none;
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .slide-cta__panel { transition: opacity 0.3s ease; transform: none; }
  }
</style>

<script>
  const wrap = document.querySelector<HTMLElement>('[data-slide-cta]');
  if (wrap) {
    const KEY = 'slide-cta-dismissed';
    const closeBtn = wrap.querySelector<HTMLElement>('[data-slide-cta-close]');
    let shown = false;

    const reveal = () => {
      if (shown || sessionStorage.getItem(KEY)) return;
      shown = true;
      wrap.classList.remove('hidden');
      void wrap.offsetWidth; // reflow so the transition runs from the off-screen start
      wrap.setAttribute('data-open', '');
      window.removeEventListener('scroll', onScroll);
    };

    const onScroll = () => {
      const progress = (window.scrollY + window.innerHeight) / document.body.scrollHeight;
      if (progress > 0.45) reveal();
    };

    closeBtn?.addEventListener('click', () => {
      wrap.removeAttribute('data-open');
      sessionStorage.setItem(KEY, '1');
      window.setTimeout(() => wrap.classList.add('hidden'), 500);
    });

    if (!sessionStorage.getItem(KEY)) window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
