---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import type { ImageMetadata } from 'astro';

// Split hero for the product pages: title + subtitle + button on the LEFT, a
// product screenshot on the RIGHT. NOT the centred PageHero, which these pages
// were wrongly using — that rendered the image as a full-bleed background with
// the text stacked and centred over it.
//
// Two themes, both measured on the originals at 1440:
//   dark   platform          navy bg, white h1 42px, 588x342 <img> right
//   light  jobadvertising    white bg, navy h1 40px + button, image contain
//                            right (the original sets it as a right-anchored
//                            `background-size: contain` layer; we render the
//                            same image as a right-aligned <img>)
//
// Row is 1200 wide; the text column is the left half.

interface Props {
  title: string;
  /**
   * Render the title as raw HTML instead of plain text. jobadvertising's
   * original h1 is literally `Job <br>Advertising` — a hard break after the
   * first word — so "Job" sits on one line and "Advertising" on the next.
   * Same visible copy, matched line breaks. Falls back to `title`.
   */
  titleHtml?: string | null;
  subtitle?: string | null;
  /**
   * Render the subtitle as raw HTML instead of plain text, for a matched hard
   * break. jobboost's original h2 is `Boost jouw vacature en <br>vergroot de
   * zichtbaarheid!` — two lines, broken after "en". Falls back to `subtitle`.
   */
  subtitleHtml?: string | null;
  cta?: { label: string; href: string } | null;
  image?: ImageMetadata;
  imageWidth?: number;
  imageHeight?: number;
  theme?: 'dark' | 'light';
  /**
   * Render the subtitle as a lilac 30px second line INSIDE the h1, the way
   * platform's original does ("Ontdek de mogelijkheden" in #e9b9ec). Off by
   * default — jobadvertising's subtitle is ordinary body text below the h1.
   */
  subtitleInHeading?: boolean;
  /**
   * Place the image as a bottom-centre CSS background behind the text rather
   * than as a side column. jobboost's hero does this (background-position
   * 50% 100%); platform and jobadvertising put the image on the right.
   */
  imageAsBackdrop?: boolean;
}

const {
  title,
  titleHtml = null,
  subtitle = null,
  subtitleHtml = null,
  cta = null,
  image,
  imageWidth = 588,
  imageHeight = 342,
  theme = 'dark',
  subtitleInHeading = false,
  imageAsBackdrop = false,
} = Astro.props;

const dark = theme === 'dark';
const backdrop = imageAsBackdrop && image;

// The desktop image column tracks the passed width. jobadvertising's original
// serves a big right-anchored dashboard (renders ~812x552); we go to 720 to
// get close. Platform stays at 588. Both literals live here so Tailwind keeps
// them. */
const imageColClass = imageWidth >= 700 ? 'lg:w-[720px]' : 'lg:w-[588px]';
---

<section
  class:list={[dark ? 'bg-navy' : 'bg-white', 'px-6 pt-[100px]', backdrop ? 'hero-backdrop pb-12 md:pb-0' : 'pb-[60px]']}
  style={backdrop ? `background-image:url(${image!.src});background-position:50% 100%;background-size:auto;background-repeat:no-repeat` : undefined}
>
  <div
    class:list={[
      'mx-auto flex max-w-[1200px] gap-10',
      backdrop ? 'flex-col md:min-h-[397px]' : 'flex-col items-center lg:flex-row lg:gap-20',
    ]}
  >
    <div class="lg:flex-1">
      <h1
        class:list={[
          'font-display font-bold',
          subtitleInHeading ? 'text-[42px] leading-[46px]' : 'text-[40px] leading-[48px]',
          dark ? 'text-white' : 'text-navy',
        ]}
      >
        {titleHtml ? <Fragment set:html={titleHtml} /> : title}
        {subtitle && subtitleInHeading && (
          <span class="mt-1 block text-[30px] leading-[36px] text-lilac">{subtitle}</span>
        )}
      </h1>

      {/* The original renders this as an H2 at 24px/26.4px (both product pages),
          not a small paragraph. Keep it a <p> for heading hierarchy, matched
          size. */}
      {subtitle && !subtitleInHeading && (
        <p class:list={['mt-6 text-[24px] leading-[26.4px]', dark ? 'text-white' : 'text-navy']}>
          {subtitleHtml ? <Fragment set:html={subtitleHtml} /> : subtitle}
        </p>
      )}

      {cta && (
        <div class="mt-8">
          <Button href={cta.href} label={cta.label} height={52} />
        </div>
      )}
    </div>

    {image && !backdrop && (
      <Image
        src={image}
        alt=""
        width={imageWidth}
        height={imageHeight}
        densities={[1, 2]}
        class:list={['h-auto w-full lg:shrink-0', imageColClass]}
      />
    )}
  </div>
</section>

<style>
  /* jobboost's photo-collage backdrop is a desktop-only decoration: the original
     hides it below 768px, where it sat behind the title and hurt legibility.
     Match that — no background image on mobile, so the title reads on plain bg. */
  @media (max-width: 767px) {
    .hero-backdrop {
      background-image: none !important;
    }
  }
</style>
