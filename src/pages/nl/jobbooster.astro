---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/sections/PageHero.astro';
import PricingTier from '../../components/ui/PricingTier.astro';
import ContactCta from '../../components/sections/ContactCta.astro';
import Accordion from '../../components/ui/Accordion.astro';
import Reveal from '../../components/ui/Reveal.astro';
import page from '../../i18n/pages/nl-jobbooster.json';
import { bandFor, heroBand } from '../../lib/bands';

// /nl/jobbooster — a standalone product/pricing page the original serves at
// 200, distinct from /nl/oplossingen/jobboost. It was missing entirely: the
// extracted data existed (nl-jobbooster.json) but nothing rendered it.
//
// Structure, measured on the original (sectionBands):
//   hero    "De ultieme vacature booster…"  ink band, centred title + intro
//   pricing "Kies een boost pakket"          fog band, intro + 3 tiers
//   form    "Een vacature booster aanvragen" ink band, the page's own 6-field
//                                            form (a w.jpg portrait sits beside
//                                            it on the original — TODO: fetch
//                                            that asset in the parity/asset
//                                            sweep; rendered centred for now)
//   faq     "Veelgestelde vragen"            white, 7-item accordion

const hero = page.heroSlider?.[0] ?? { title: page.hero.title, body: null };

// The tiers carry price ("€325") and info ("Excl. BTW per vacature") already;
// the `tag` field just concatenates the two, so null it to avoid rendering the
// price twice (the original box shows price + info + description only).
const tiers = (page.pricing ?? []).map((t) => ({ ...t, tag: null }));

const pricing = page.blocks?.find((b: any) => b.heading?.startsWith('Kies een boost'));
const pricingHeading = pricing?.heading ?? 'Kies een boost pakket';
const pricingIntro = pricing?.body?.[0] ?? null;

const form = page.forms?.[0] ?? null;
const formHeading = form?.title ?? 'Een vacature booster aanvragen';

const faqHeading =
  page.headings.find((h) => h.startsWith('Veelgestelde')) ?? 'Veelgestelde vragen';
---

<Base title={page.meta.title} description={page.meta.description ?? undefined}>
  {/* Centred hero on the dark ink band (#111d29), not navy. */}
  <PageHero title={hero.title} subtitle={hero.body} band={heroBand(page)} />

  {/* "Kies een boost pakket" — intro + three package cards, on the fog band. */}
  <section class="px-6 py-[70px]" style={`background-color:${bandFor(page, 'Kies een boost') ?? '#f8f9fb'}`}>
    <div class="mx-auto max-w-[1200px]">
      <h2 class="text-center font-display text-[30px] leading-[33px] font-bold text-navy">
        {pricingHeading}
      </h2>
      {pricingIntro && (
        <p class="mx-auto mt-4 max-w-[900px] text-center text-[16px] leading-[26px] text-navy">
          {pricingIntro}
        </p>
      )}
      <Reveal variant="zoom" duration={1000} class="mt-11 flex flex-wrap justify-center -mx-3">
        {tiers.map((tier) => (
          <div class="mb-6 w-full px-3 md:w-1/2 lg:w-1/3">
            <PricingTier {...tier} />
          </div>
        ))}
      </Reveal>
    </div>
  </section>

  {/* The page's own form on the ink band — 6 fields, submit "Verzenden". */}
  <ContactCta
    title={formHeading}
    intro={null}
    band={bandFor(page, 'Een vacature booster')}
    id="Contactjobbooster"
    fields={form?.fields ?? undefined}
    submitLabel={form?.submitLabel ?? undefined}
  />

  {/* FAQ — centred, full-width accordion (no side image on this page). */}
  {page.accordion?.length > 0 && (
    <section class="bg-white px-6 py-[60px]">
      <div class="mx-auto max-w-[850px]">
        <h2 class="mb-6 text-center font-display text-[30px] leading-[33px] font-bold text-navy">
          {faqHeading}
        </h2>
        <Accordion items={page.accordion} />
      </div>
    </section>
  )}
</Base>
