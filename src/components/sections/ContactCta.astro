---
import FormStub from '../ui/FormStub.astro';
import copy from '../../i18n/home-copy.json';

// Measured @1440:
//   section  y=4575 1440×894, bg mist, padding 96px 24px
//   h2       650 wide, centred, Poppins 700 30px/33px
//   intro    650 wide, 16px/22.4px
//   form     800 wide, centred
// `title` is REQUIRED on purpose. It used to default to the homepage's CTA
// copy, and six pages that omitted it silently rendered the wrong heading —
// see src/lib/cta.ts. A required prop turns that into a build error.
interface Props {
  title: string;
  intro?: string | null;
  /**
   * Band colour, from the page's own extracted sectionBands.
   *
   * NOT constant across the site: navy on /nl/over-ons, mist on /nl/actueel,
   * fog on the FAQ. Defaults to mist, which is what the homepage uses.
   */
  band?: string | null;
  /** Anchor id, so in-page CTAs (jobboost's pricing buttons) can scroll here. */
  id?: string;
  /**
   * Override the form fields. Defaults to the shared homepage form, but pages
   * with their own form shape pass it — jobboost adds a "Welke boost past bij
   * jou?" checkbox group (Small / Medium / Large) the generic form lacks.
   */
  fields?: any[];
  submitLabel?: string;
}
const {
  title,
  intro = null,
  band = null,
  id,
  fields = copy.contactCta.fields,
  submitLabel = copy.contactCta.submitLabel,
} = Astro.props;

// Navy bands need light text; the light bands keep navy text.
const onDark = !!band && /rgb\(\s*17,\s*(65|29)/.test(band);
---

<section
  id={id}
  class="scroll-mt-24 bg-mist px-6 py-24"
  style={band ? `background-color:${band}` : undefined}
>
  <div class="mx-auto max-w-[800px]">
    {/* Intro spans the form column (~800), not a narrower 650 — measured at
        822 on /nl/contact. */}
    <div class="mx-auto max-w-[800px] text-center">
      <h2
        class:list={[
          'font-display text-[30px] leading-[33px] font-bold',
          onDark ? 'text-white' : 'text-navy',
        ]}
      >
        {title}
      </h2>
      {intro && (
        <p class:list={['mt-6 text-[16px] leading-[22.4px]', onDark ? 'text-white' : 'text-navy']}>
          {intro}
        </p>
      )}
    </div>

    <div class="mt-11">
      {/* Field set is identical across pages on the original, so it stays
          sourced from the homepage extraction rather than duplicated. */}
      <FormStub fields={fields} submitLabel={submitLabel} />
    </div>
  </div>
</section>
