---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/sections/Hero.astro';
import FeatureBand from '../../components/sections/FeatureBand.astro';
import ValueProp from '../../components/sections/ValueProp.astro';
import CtaStrip from '../../components/sections/CtaStrip.astro';
import ProductBlock from '../../components/sections/ProductBlock.astro';
import CaseSection from '../../components/sections/CaseSection.astro';
import ContactCta from '../../components/sections/ContactCta.astro';
import LogoWall from '../../components/sections/LogoWall.astro';
import TestimonialCarousel from '../../components/sections/TestimonialCarousel.astro';
import StatsBand from '../../components/sections/StatsBand.astro';
import copy from '../../i18n/home-copy.json';
import productJobAdvertising from '../../assets/product-jobadvertising.png';
import productJobboost from '../../assets/product-jobboost.png';

// TWO alternating product blocks: Job Advertising (image right) and Jobboost
// (image left). The LIVE original also has a "Multiposter" block in its HTML
// but hides it at every width (both instances render 0×0), so it is NOT shown
// to users — we don't render it either. (An earlier heading-parity check
// flagged it as "missing" because it counts hidden headings in the markup.)
const blockImages = [productJobAdvertising, productJobboost];
---

<Base
  title="Jobmatix | Hét job marketing platform dat voor je werkt!"
  description="Benieuwd hoe jij jouw job marketing eenvoudig vanuit één plek kunt beheren, automatiseren en optimaliseren?"
>
  <Hero />
  <FeatureBand />
  <ValueProp />
  <CtaStrip />

  {copy.productBlocks.map((block, i) => (
    <ProductBlock
      title={block.title}
      body={block.body}
      image={blockImages[i]}
      cta={block.cta}
      {/* Block 1 puts the image on the RIGHT, block 2 on the left. */}
      reverse={i % 2 === 0}
      reveal={i % 2 === 0 ? 'left' : 'right'}
      background={i % 2 === 0 ? 'mist' : 'white'}
      properties={block.properties ?? []}
    />
  ))}

  <StatsBand />

  <CaseSection />

  <TestimonialCarousel />

  <LogoWall />

  <ContactCta title={copy.contactCta.title} intro={copy.contactCta.intro} />
</Base>
