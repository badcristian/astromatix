---
// The /nl/actueel hero: a navy band with just the heading and tagline. The
// category filter buttons are NOT inside it — on the original they sit as navy
// pill buttons on the fog band immediately below (ArticleListing renders them).
// Shorter than the shared PageHero: the heading sits ~70px below the header on
// the original, not 200.

interface Props {
  title: string;
  subtitle?: string | null;
}

const { title, subtitle = null } = Astro.props;
---

<section class="bg-navy px-6 pt-[70px] pb-10 text-center text-white">
  <div class="container-site">
    <h1 class="font-display text-[40px] leading-[48px] font-bold text-white">{title}</h1>
    {subtitle && (
      <p class="mx-auto mt-3 max-w-[760px] text-[16px] leading-[24px] text-white/90">{subtitle}</p>
    )}
  </div>
</section>
