---
import { resolveIcon } from '../../lib/icons';
import { Image } from 'astro:assets';

// The original's `.quickfeat`. Measured @1440 on /nl/oplossingen/jobboost:
//   grid   col s4 md-s6 sm-s12 — three across, 379px columns
//   item   355 wide: a 29px icon column beside a 326px text column
//   title  h4, Poppins 700 20px, 254 wide
//   desc   Manrope 14.4px, 254 wide
//
// Icons are inline SVG in the theme rather than <img>, so the extractor finds
// no URL for them. Falls back to a shared glyph until they are traced.

interface Props {
  items: { title: string | null; body: string | null; icon?: string | null }[];
}

const { items } = Astro.props;
---

<div class="flex flex-wrap -mx-3">
  {items.map((item) => {
    const icon = resolveIcon(item.icon);
    return (
      <div class="w-full px-3 pb-12 md:w-1/2 lg:w-1/3">
        <div class="flex gap-6">
          <span class="mt-1 size-[29px] shrink-0 text-orange" aria-hidden="true">
            {icon ? (
              <Image src={icon} alt="" width={29} densities={[1, 2]} />
            ) : (
              <svg width="29" height="29" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9" />
                <path d="M8 12l3 3 5-6" />
              </svg>
            )}
          </span>

          <div class="max-w-[254px]">
            {item.title && (
              <h4 class="font-display text-[20px] leading-[28px] font-bold text-navy">
                {item.title}
              </h4>
            )}
            {item.body && (
              <p class="mt-2 text-[14.4px] leading-[20.16px] text-navy">{item.body}</p>
            )}
          </div>
        </div>
      </div>
    );
  })}
</div>
