---
import QuickFeat from '../ui/QuickFeat.astro';
import ContactCta from './ContactCta.astro';
import { Image } from 'astro:assets';
import { resolveIcon } from '../../lib/icons';

// The rendered body of a customer story, shared by the clean
// /nl/actueel/klantcase/[slug] route and the two doubled /nl/nl/ routes that
// the original also serves (kruidvat, dhl-express). Driven by the page's FULL
// document order (see caseData / the extractor's `order` field) so the block
// kinds interleave exactly as the original — faam runs three narrative
// sections and a single closing quote; djops runs four sections with a quote
// card BETWEEN them (Uitdaging → quote → De oplossing → Het resultaat → quote).
//
// Structure, measured on royal-schiphol-group @1440:
//   hero      full-bleed background photo, two-tone <h1>
//   tags      properties band, #f8f9fb, inline-SVG glyph per tag
//   lead      centred headline + intro + a row of square sector tiles
//   section   narrative heading + body + photos, on its own band colour; the
//             first also carries the client-profile card as a right sidebar
//   quote     a compact-card on a navy band
//   CTA       "Get the job done" + form

interface Props {
  c: ReturnType<typeof import('../../lib/klantcases').caseData>;
}

const { c } = Astro.props;

const heroBg = resolveIcon(c.heroBackground);

// Animated GIFs cannot go through astro:assets — sharp flattens them to a
// single frame — so they live in /public and render as a plain <img>. jam-werkt's
// "Uitdaging" is a 3-frame GIF that cycles through team photos; keyed by the
// original filename so the extractor's src maps to the local copy.
const GIF_PUBLIC: Record<string, { src: string; width: number; height: number }> = {
  'Ontwerp zonder titel (2).gif': { src: '/klantcases/jam-werkt-uitdaging.gif', width: 792, height: 549 },
};
const gifFor = (src: string) => {
  const name = decodeURIComponent((src.split('/').pop() ?? '').split('?')[0]);
  return GIF_PUBLIC[name] ?? null;
};

// Resolve a content image's local asset; a square tile shrinks below 640.
const resolveImg = (img: { src: string; width: number; height: number }) => ({
  ...img,
  resolved: resolveIcon(img.src),
  gif: gifFor(img.src),
});

// Section heading size is NOT uniform across the six cases: five run every
// heading at the 40px "H2" size, but djops authors its narrative sections one
// step down at the 28px "H3" size (its lead headline stays 40px). The original
// heading level rides on each part, so mirror it — level 3 → 28/35 (24/30 on
// mobile), everything else → the 40/44 default (30/33 on mobile). Both were
// measured @1440 and @390 on the live original.
const headingClass = (level: number) =>
  level >= 3
    ? 'font-display text-[24px] leading-[30px] font-bold text-navy lg:text-[28px] lg:leading-[35px]'
    : 'font-display text-[30px] leading-[33px] font-bold text-navy lg:text-[40px] lg:leading-[44px]';
---

{/* --- hero: full-bleed photo, two-tone heading ------------------------- */}
<section
  class="relative bg-navy bg-cover bg-center px-6"
  style={heroBg ? `background-image:url(${heroBg.src})` : undefined}
>
  <div
    class:list={[
      'mx-auto flex min-h-[348px] max-w-[1200px] items-center',
      c.heroCentered && 'justify-center',
    ]}
  >
    {/* Fonts scale with the viewport so a long client name ("Djops
        Uitzendgroep") does not overflow the right edge on mobile, while the
        original desktop sizes are the clamp ceiling. */}
    <h1 class:list={['max-w-[760px] font-display font-bold break-words', c.heroCentered && 'text-center']}>
      {c.heroCentered ? (
        <>
          {/* djops: centred white title + a small lilac subtitle line. */}
          <span class="block text-white" style="font-size:clamp(30px, 9vw, 60px);line-height:1.08">{c.title}</span>
          {c.heroSubtitle && (
            <span class="mt-3 block text-[20px] leading-[25px]" style="color:#e9b9ec">{c.heroSubtitle}</span>
          )}
        </>
      ) : c.heroParts.length > 0 ? (
        c.heroParts.map((part) => (
          <span
            class="block"
            style={`font-size:clamp(24px, 8vw, ${part.fontSize});line-height:1.08;color:${part.color}`}
          >
            {part.text}
          </span>
        ))
      ) : (
        <span class="block text-white" style="font-size:clamp(30px, 9vw, 60px);line-height:1.08">{c.title}</span>
      )}
    </h1>
  </div>
</section>

{/* --- properties band -------------------------------------------------- */}
{c.tags.length > 0 && (
  <section class="bg-fog px-6 py-5">
    <div class="mx-auto flex max-w-[1200px] flex-wrap items-center justify-center gap-x-12 gap-y-3">
      {c.tags.map((tag) => (
        <span class="flex items-center gap-3 text-[16px] text-navy">
          {tag.iconSvg && (
            // Build-time markup we extracted ourselves, not user input.
            <span class="inline-block size-6 shrink-0 [&>svg]:size-6 [&>svg]:fill-current" set:html={tag.iconSvg} />
          )}
          {tag.label}
        </span>
      ))}
    </div>
  </section>
)}

{/* --- blocks, in exact document order ---------------------------------- */}
{c.render.map((item) => {
  if (item.kind === 'quote') {
    const portrait = resolveIcon(item.image);
    const CardInner = (
      <>
        {/* Compact card measured on the original: 384x69, 44px avatar, name
            16/500, role 14.4/400, 16px radius, 12/18 padding — NOT the 96px
            avatar + 20px bold we had, which ran it ~2x too tall. */}
        {portrait && (
          <Image src={portrait} alt="" width={44} height={44} densities={[1, 2]} class="size-11 shrink-0 rounded-full object-cover" />
        )}
        <div class="min-w-0 flex-1">
          <p class="text-[16px] leading-[22px] font-medium text-navy">{item.title}</p>
          {item.body && <p class="text-[14.4px] leading-[20px] text-navy">{item.body}</p>}
        </div>
        {/* The card links to the person's LinkedIn, with a trailing arrow. */}
        {item.link && (
          <svg class="size-5 shrink-0 text-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        )}
      </>
    );
    return (
      <section class="bg-navy px-6 py-10">
        <div class="mx-auto max-w-[1000px] text-center">
          {item.text && (
            <blockquote class="text-[16px] leading-[22.4px] text-white">{item.text}</blockquote>
          )}
          <div class="mt-8 flex justify-center">
            {item.link ? (
              <a
                href={item.link}
                rel="noopener"
                target="_blank"
                class="flex w-full max-w-[384px] items-center gap-4 rounded-2xl bg-white py-3 pr-[18px] pl-[18px] text-left shadow-card transition-transform hover:scale-[1.02]"
              >
                {CardInner}
              </a>
            ) : (
              <div class="flex w-full max-w-[384px] items-center gap-4 rounded-2xl bg-white py-3 pr-[18px] pl-[18px] text-left shadow-card">
                {CardInner}
              </div>
            )}
          </div>
        </div>
      </section>
    );
  }

  // A narrative (or lead) section.
  const images = item.images.map(resolveImg).filter((i) => i.resolved || i.gif);

  // An image laid out past centre on the original (djops "Het resultaat":
  // 588px at x=732) is a RIGHT column beside the text, not a full-width photo
  // below it. Only applies when the section has no profile sidebar.
  const sideImage = !item.card && images.length === 1 && (images[0].x ?? 0) > 700 ? images[0] : null;
  const belowImages = sideImage ? [] : images;

  // Whether this section is centred is authored per page/section on the original
  // and carried on the data (item.align) — "Oplossing" is centred everywhere,
  // "Resultaat" is centred on some pages and left on others. Card / side-image
  // sections stay left (two-column) regardless.
  const centered = item.align === 'center' && !item.card && !sideImage;

  if (item.lead) {
    const lead = item.parts[0];
    // djops closes its lead with a metric row: three ~200px "coin" images, each
    // captioned by the LAST body lines ("Een daling van de CPA", …). When the
    // trailing body lines match the image count and read like short captions,
    // pair image[i] with caption[i] and lay them out as spread columns; the
    // earlier body lines stay narrative paragraphs.
    const metricImgs = images.filter((i) => (i.width ?? 0) <= 260);
    const trailing = lead.body.slice(-metricImgs.length);
    // A caption is short — but faam's run to ~75 chars ("...het aantal
    // sollicitaties met 45% gestegen."), longer than djops/royal's terse labels,
    // so allow up to 80. The 1:1 match with coin-sized (≤260px) images is what
    // actually identifies the metric row; the length is only a false-positive guard.
    const paired =
      metricImgs.length >= 2 &&
      metricImgs.length === images.length &&
      lead.body.length > metricImgs.length &&
      trailing.every((t) => t.length <= 80);
    const narrative = paired ? lead.body.slice(0, -metricImgs.length) : lead.body;
    return (
      <section
        class:list={['px-6 pt-[50px]', paired && 'pb-[50px]']}
        style={item.band ? `background-color:${item.band}` : undefined}
      >
        <div class="mx-auto max-w-[1138px] text-center">
          <h2 class={headingClass(lead.level)}>{lead.heading}</h2>
          {narrative.map((para) => (
            <p class="mx-auto mt-4 max-w-[900px] text-[16px] leading-[26px] text-navy">{para}</p>
          ))}
          {paired ? (
            <div class="mt-12 grid grid-cols-1 gap-10 sm:grid-cols-3">
              {metricImgs.map((img, i) => (
                <div class="flex flex-col items-center gap-4">
                  <Image src={img.resolved!} alt="" width={img.width} height={img.height} class="size-[200px] object-contain" />
                  <p class="text-[16px] leading-[22px] text-navy">{trailing[i]}</p>
                </div>
              ))}
            </div>
          ) : (
            images.length > 0 && (
              <div class="mt-8 flex flex-wrap items-center justify-center gap-6">
                {images.map((img) => (
                  <Image
                    src={img.resolved!}
                    alt=""
                    width={img.width}
                    height={img.height}
                    class:list={['h-auto rounded-3xl', img.width > 400 ? 'w-full' : 'w-[130px] sm:w-[200px]']}
                  />
                ))}
              </div>
            )
          )}
        </div>
      </section>
    );
  }

  return (
    <section class="px-6 py-[50px]" style={item.band ? `background-color:${item.band}` : undefined}>
      <div
        class:list={[
          'mx-auto max-w-[1200px]',
          (item.card || sideImage) && 'flex flex-col gap-8 lg:flex-row lg:items-start lg:gap-[42px]',
          centered && 'text-center',
        ]}
      >
        <div class:list={[item.card && 'lg:w-[792px] lg:shrink-0', sideImage && 'lg:flex-1']}>
          {item.parts.map((part, pi) => (
            <>
              <h2 class:list={[headingClass(part.level), pi > 0 && 'mt-10']}>
                {part.heading}
              </h2>
              {part.body.map((para) => (
                <p class:list={['mt-4 text-[16px] leading-[26px] text-navy', centered && 'mx-auto max-w-[900px]']}>{para}</p>
              ))}
            </>
          ))}
          {belowImages.map((img) =>
            img.gif ? (
              <img src={img.gif.src} alt="" width={img.gif.width} height={img.gif.height} loading="lazy" class="mt-8 h-auto w-full rounded-3xl" />
            ) : (
              <Image src={img.resolved!} alt="" width={img.width} height={img.height} class="mt-8 h-auto w-full rounded-3xl" />
            ),
          )}
          {item.quickfeat.length > 0 && (
            // The quickfeat grid stays left-aligned even inside a centred section.
            <div class:list={['mt-10', centered && 'text-left']}>
              <QuickFeat items={item.quickfeat} columns={2} />
            </div>
          )}
        </div>

        {sideImage && (
          <Image
            src={sideImage.resolved!}
            alt=""
            width={sideImage.width}
            height={sideImage.height}
            class="h-auto w-full rounded-3xl lg:w-[588px] lg:shrink-0"
          />
        )}

        {item.card && (
          <aside class="rounded-3xl bg-white p-6 shadow-card lg:w-[282px] lg:shrink-0">
            <h3 class="font-display text-[20px] leading-[28px] font-bold text-navy">{item.card.title}</h3>
            <p class="mt-3 text-[14.4px] leading-[20.16px] text-navy">{item.card.body}</p>
          </aside>
        )}
      </div>
    </section>
  );
})}

<ContactCta
  title={c.ctaTitle ?? undefined}
  intro={c.ctaIntro}
  fields={c.formFields ?? undefined}
  submitLabel={c.formSubmitLabel ?? undefined}
  wide
/>
