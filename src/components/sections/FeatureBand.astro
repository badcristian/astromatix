---
import PropertyItem from '../ui/PropertyItem.astro';
import Reveal from '../ui/Reveal.astro';
import { home } from '../../i18n/nl';

interface Props {
  items?: { icon: string; label: string }[];
  /**
   * White chip behind each glyph. The homepage band has it (`.icon--square`);
   * the product-page bands are bare glyphs — so those pass chip={false}.
   */
  chip?: boolean;
}
// Defaults to the homepage band; product pages pass their own four items.
const { items = home.featureBand, chip = true } = Astro.props;

// Measured @1440:
//   band       1440×88, padding 10px 24px
//   background rgba(255,255,255,0.1) over the hero's navy — the original does
//              this with a linear-gradient, we use a plain translucent white
//   items row  x=153 w=1133, centred; items 44px tall at y=647
//   gaps       ~27–28px between items, with a hairline divider
//
// The original overlaps this strip onto the bottom of the hero section. We
// render it as a sibling immediately after, with the hero's bottom padding
// reduced to match — same rendered result, simpler markup.
---

<section class="bg-navy">
  <Reveal variant="up" duration={500} class="bg-white/10 px-6 py-4 lg:py-[10px]">
    {/* Mobile: a vertical stack, each item its own full-width row (matching the
        original — a fixed-height flex-wrap row overlapped the items). From lg:
        one 68px centred row with hairline dividers (items are 44px, vertically
        centred with 12px above/below; 10px padding makes the strip 88). */}
    <div class="flex flex-col items-center gap-4 lg:h-[68px] lg:flex-row lg:flex-wrap lg:items-center lg:justify-center lg:gap-0">
      {items.map((item, i) => (
        <div
          class:list={[
            // ~25px trailing space per item (except the last) on the original.
            i < items.length - 1 && 'lg:pr-[25px]',
            i > 0 && 'lg:ml-[14px] lg:border-l lg:border-white/20 lg:pl-[14px]',
          ]}
        >
          <PropertyItem icon={item.icon} label={item.label} variant="light" chip={chip} />
        </div>
      ))}
    </div>
  </Reveal>
</section>
