---
// The original's `.properties__item` — an icon glyph plus a label. It recurs
// across the homepage (hero band in white-on-navy) and voor-wie (navy on
// white), so it lives in ui/ rather than inside any one section.
//
// The glyph is a BARE coloured SVG — NOT an icon in a chip. An earlier version
// wrapped it in a 44×44 white rounded square (`bg-white`); the original has no
// such chip. On the navy hero band that white square was very visible and
// wrong; on voor-wie's white background it was invisible but still not the
// original. Measured @1440 on the live site:
//   band (light)   glyph 18×18, WHITE, transparent behind, label 16/22.4 white
//   voor-wie(dark) glyph 29×29, NAVY,  transparent behind, label 16/22.4 navy
//   label sits 7px after the glyph
//
// Glyphs are our own equivalents of the theme's icon set, not traced copies.

interface Props {
  icon: 'download' | 'send' | 'expand' | 'arrow';
  label: string;
  variant?: 'light' | 'dark';
  size?: 'default' | 'small';
}

const { icon, label, variant = 'light', size = 'default' } = Astro.props;

// Glyph colour and size track the original per context: white 18px on the
// navy bands, navy 29px in voor-wie's light list.
const glyphPx = variant === 'dark' ? 29 : 18;
const iconColor = variant === 'light' ? 'text-white' : 'text-navy';

const paths: Record<Props['icon'], string> = {
  download: 'M12 3v11m0 0l-4-4m4 4l4-4M4 19h16',
  send: 'M21 3L3 10.5l7 3 3 7L21 3z',
  expand: 'M12 3v18M3 12h18M8 7l4-4 4 4M8 17l4 4 4-4M7 8l-4 4 4 4M17 8l4 4-4 4',
  arrow: 'M4 12h15m0 0l-5-5m5 5l-5 5',
};

const labelClass = size === 'small' ? 'text-[14px] leading-[20px]' : 'text-[16px] leading-[22.4px]';
---

<div class="inline-flex items-center gap-[7px]">
  <span class:list={['flex shrink-0 items-center justify-center', iconColor]}>
    <svg
      width={glyphPx}
      height={glyphPx}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d={paths[icon]} />
    </svg>
  </span>
  <span class={`${labelClass} ${iconColor}`}>{label}</span>
</div>
