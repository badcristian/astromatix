---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/sections/PageHero.astro';
import ArticleListing from '../../components/sections/ArticleListing.astro';
import ContactCta from '../../components/sections/ContactCta.astro';
import { ctaHeading } from '../../lib/cta';
import page from '../../i18n/pages/nl-actueel.json';
import { bandFor, heroBand } from '../../lib/bands';

// The unfiltered hub. Category views live at /nl/actueel/[category] and are
// generated from the same component — see ArticleListing.astro for why this
// page is the rebuild's strongest single argument.
const helpBody = page.blocks.find((b: any) => b.heading === 'We helpen je graag')?.body?.[0] ?? null;
---

<Base title="Actueel — Jobmatix" description="Nieuws, blogs, kennis en events van Jobmatix.">
  {/* The hero heading is "Kennis & Updates" (not "Actueel"), with the tagline
      below it — both measured on the original's hero. */}
  <PageHero
    title={page.blocks[0]?.heading ?? 'Kennis & Updates'}
    subtitle="Ontdek wat er speelt in de wereld van job marketing!"
  />
  <ArticleListing />
  <ContactCta
    title={ctaHeading(page, 'actueel')}
    intro={helpBody}
    band={bandFor(page, 'Vragen, opmerkingen')}
  />
</Base>
