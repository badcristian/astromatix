---
// The original's `.accordion`. Measured @1440 on /nl/oplossingen/jobadvertising:
//   wrapper  white, 24px radius, padding 96px 24px
//   item     1px #f5f5ff bottom border, 24px bottom padding
//   header   40px tall, flex space-between, pointer cursor
//   title    Manrope 400 16px/22.4px navy
//   details  16px/22.4px navy
//   chevron  40×40 navy
//
// Built on <details>/<summary> so it works without JavaScript and is keyboard
// and screen-reader accessible by default — the original wires this up with a
// click handler on a plain div, which is neither.

interface Props {
  items: { question: string; answer: string }[];
  /** Index of the item open on load, or null for all closed. */
  openIndex?: number | null;
  /**
   * Render the white rounded card around the items.
   *
   * The 96px vertical padding was measured on a page with ONE accordion. The
   * FAQ actually has three (one per category), so leaving it on meant ~576px
   * of padding where the original has 192. Groups pass chrome={false} and the
   * page supplies a single card around all of them.
   */
  chrome?: boolean;
  /**
   * Section heading rendered INSIDE the card, above the items — the original's
   * "Veelgestelde vragen" sits within the accordion card, not above it. Only
   * shown with chrome (the multi-category FAQ page supplies its own headings).
   */
  heading?: string | null;
}

const { items, openIndex = null, chrome = true, heading = null } = Astro.props;
---

<div class:list={[chrome && 'rounded-3xl bg-white px-6 py-24 shadow-card-lg']}>
  {heading && chrome && (
    <h2 class="mb-[50px] font-display text-[28px] leading-[33px] font-bold text-navy">{heading}</h2>
  )}
  {items.map((item, i) => (
    <details
      class="faq-item group border-b border-mist pb-6 [&:not(:first-child)]:pt-6"
      open={i === openIndex}
    >
      {/* Question title: 20px Poppins 700 (the theme's .accordion__title.h4),
          not the 16px Manrope the wrapper measured at. */}
      <summary
        class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-[20px] leading-[28px] font-bold text-navy marker:hidden [&::-webkit-details-marker]:hidden"
      >
        {item.question}
        <span
          class="grid size-10 shrink-0 place-items-center text-navy transition-transform group-open:rotate-180"
          aria-hidden="true"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </span>
      </summary>

      <div class="mt-3 text-[16px] leading-[22.4px] text-navy">
        <Fragment set:html={item.answer} />
      </div>
    </details>
  ))}
</div>

<style>
  /* Smoothly reveal the answer when an item opens, using the modern
     ::details-content pseudo + interpolate-size (so height can animate to auto).
     Progressive enhancement: browsers without support simply snap open. */
  .faq-item {
    interpolate-size: allow-keywords;
  }
  .faq-item::details-content {
    block-size: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      block-size 300ms ease,
      opacity 250ms ease,
      content-visibility 300ms allow-discrete;
  }
  .faq-item[open]::details-content {
    block-size: auto;
    opacity: 1;
  }
</style>
