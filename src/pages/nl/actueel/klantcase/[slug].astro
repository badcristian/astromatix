---
import Base from '../../../../layouts/Base.astro';
import KlantcaseArticle from '../../../../components/sections/KlantcaseArticle.astro';
import { KLANTCASES, caseData } from '../../../../lib/klantcases';

// Six customer stories, one template — the body lives in KlantcaseArticle so
// the two doubled /nl/nl/ routes the original also serves (kruidvat,
// dhl-express) render identically without duplicating the layout.

export function getStaticPaths() {
  return KLANTCASES.map((c) => ({ params: { slug: c.slug }, props: { entry: c } }));
}

const { entry } = Astro.props;
const c = caseData(entry);
---

<Base title={c.meta.title} description={c.meta.description ?? undefined}>
  <KlantcaseArticle c={c} />
</Base>
