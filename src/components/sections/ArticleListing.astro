---
import { Image } from 'astro:assets';
import { resolveIcon } from '../../lib/icons';
import listing from '../../i18n/pages/listing.json';

// THE headline improvement over the original.
//
// The live site renders these cards client-side with List.js into an empty
// <div>: non-JS crawlers see nothing, and only 9 of the 15 entries reach the
// DOM at all (the rest are paginated away). Here every card is real HTML at
// build time, and filtering is a small progressive-enhancement island — remove
// the JS and you still have a complete, crawlable, linkable list.
//
// The original also ships /nl/actueel/{blogs,nieuws,kennis,events} as four
// byte-identical copies of this page (FINDINGS.md §6). We render them as real
// server-filtered pages instead, which makes each category deep-linkable
// rather than a JS-only view of the same URL.
//
// Source data is inconsistent (a duplicate, mixed casing, a literal "null"
// category, one category/label mismatch); scripts/extract-listing.mjs
// normalises it and reports what it changed rather than hiding it.

interface Props {
  /** Server-side filter. null renders every card with the filter bar active. */
  activeCategory?: string | null;
  /**
   * Render the internal filter bar. Off when the filters live in ListingHero
   * (the /nl/actueel pages) — the click-to-filter script queries `[data-filter]`
   * globally, so it finds the buttons wherever they are.
   */
  showFilters?: boolean;
}

const { activeCategory = null, showFilters = true } = Astro.props;

const { items, categories } = listing;

// The original orders the filters Nieuws, Kennis, Blogs, Events — not the
// alphabetical order the extractor stores.
const ORDER = ['Nieuws', 'Kennis', 'Blogs', 'Events'];
const orderedCategories = [...categories].sort(
  (a, b) => (ORDER.indexOf(a) + 1 || 99) - (ORDER.indexOf(b) + 1 || 99),
);
const visible = activeCategory ? items.filter((i) => i.category === activeCategory) : items;
const cards = visible.map((item) => ({ ...item, img: resolveIcon(item.image) }));

/** Category slug as the original routes it: /nl/actueel/blogs. */
const hrefFor = (cat: string) => `/nl/actueel/${cat.toLowerCase()}`;

// Dates arrive ISO (2025-04-08); the original shows them Dutch ("8 april
// 2025"). Format for display, keep the ISO value in the <time datetime>.
const MONTHS_NL = ['januari', 'februari', 'maart', 'april', 'mei', 'juni', 'juli', 'augustus', 'september', 'oktober', 'november', 'december'];
const formatDate = (d: string) => {
  const m = /^(\d{4})-(\d{2})-(\d{2})/.exec(d ?? '');
  return m ? `${+m[3]} ${MONTHS_NL[+m[2] - 1]} ${m[1]}` : d;
};
---

{/* fog band behind the whole listing on the original (y=292). */}
<section class="bg-fog px-6 py-16">
  <div class="mx-auto max-w-[1138px]">
    {showFilters && (
      <div class="mb-10 flex flex-wrap gap-3" role="group" aria-label="Filter op categorie">
        {/*
          Navy filled pill BUTTONS that grow slightly on hover, on the fog band
          — exactly as the original. Real links (each category is a genuine URL)
          so filtering works with no JS; the script below upgrades it to instant
          in-page filtering. The active filter is filled white with navy text.
        */}
        <a
          href="/nl/actueel"
          class="rounded-[12px] bg-navy px-[21.76px] py-3 text-[16px] font-medium text-white ring-1 ring-navy transition duration-200 hover:scale-105 aria-[current=page]:bg-white aria-[current=page]:text-navy"
          aria-current={activeCategory === null ? 'page' : undefined}
          data-filter="*"
        >
          Alles
        </a>
        {orderedCategories.map((cat) => (
          <a
            href={hrefFor(cat)}
            class="rounded-[12px] bg-navy px-[21.76px] py-3 text-[16px] font-medium text-white ring-1 ring-navy transition duration-200 hover:scale-105 aria-[current=page]:bg-white aria-[current=page]:text-navy"
            aria-current={activeCategory === cat ? 'page' : undefined}
            data-filter={cat}
          >
            {cat}
          </a>
        ))}
      </div>
    )}

    <div class="flex flex-wrap -mx-3" data-listing>
      {/* data-category is '' (not omitted) for the Alles-only cards (null
          category): the filter script collects cards via [data-category], so an
          absent attribute would drop them from filtering and leave them always
          visible. Empty matches only "*" (Alles). */}
      {cards.map((card, i) => {
        // The malformed original duplicate ("ghost") carries no href — render it
        // as a non-clickable <div> with no read-more button, matching the dead
        // page-2 card the original shows. Everything else is an <a>.
        const Wrapper = card.href ? 'a' : 'div';
        return (
          <article class="listing-card w-full px-3 pb-6 md:w-1/2 lg:w-1/3" data-category={card.category ?? ''} style={`--i:${i}`}>
            <Wrapper
              href={card.href ?? undefined}
              class:list={['flex h-full flex-col overflow-hidden rounded-3xl bg-white', card.href && 'transition-opacity hover:opacity-90']}
              {...(card.href && card.external ? { rel: 'noopener', target: '_blank' } : {})}
            >
              {card.img && (
                <Image src={card.img} alt="" width={363} height={272} class="h-[272px] w-full object-cover" />
              )}
              {/* Order per the original: category, title, DATE, excerpt, then a
                  bottom button — "Meer informatie" for the external news links,
                  "Lees verder" for the internal articles (omitted on the dead
                  ghost card). A styled span, not a nested <a>. */}
              <div class="flex flex-1 flex-col p-6">
                {/* Visible chip is the card's own label — it can differ from the
                    filter category (Programmatic Advertising shows "Kennis" but
                    filters under Events, an original quirk). */}
                <p class="text-[14.4px] uppercase text-orange">{card.label ?? card.category}</p>
                <h2 class="mt-2 font-display text-[20px] leading-[28px] font-bold text-navy">
                  {card.title}
                </h2>
                <time class="mt-3 block text-[14.4px] text-navy/60" datetime={card.date}>
                  {formatDate(card.date)}
                </time>
                <p class="mt-3 text-[14.4px] leading-[20.16px] text-navy">{card.excerpt}</p>
                {card.href && (
                  <span class="mt-6 inline-flex h-10 w-fit items-center rounded-[10px] border-2 border-mist px-[13px] text-[16px] text-navy">
                    {card.external ? 'Meer informatie' : 'Lees verder'}
                  </span>
                )}
              </div>
            </Wrapper>
          </article>
        );
      })}
    </div>

    <p class="mt-8 text-[16px] text-navy/60" data-empty hidden>
      Geen resultaten in deze categorie.
    </p>

    {/* Pager — built by JS (9 cards/page, as the original). No-JS shows every
        card, which is still a complete, crawlable list. */}
    <nav class="mt-10 hidden justify-center gap-2" data-pager aria-label="Paginering"></nav>
  </div>
</section>

<style>
  /* Cards fade + slide up, staggered by their position (--i), when switching
     category — both on client-side filter (/nl/actueel) and on load for the
     server-filtered category pages. Motion is opt-out via reduced-motion. */
  @media (prefers-reduced-motion: no-preference) {
    .listing-card {
      animation: listing-card-in 0.45s cubic-bezier(0.22, 0.61, 0.36, 1) both;
      animation-delay: calc(var(--i, 0) * 45ms);
    }
  }
  @keyframes listing-card-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Progressive enhancement: every card is real HTML and every filter is a real
  // URL, so this works with JS off. With JS it filters in place AND paginates 9
  // per page (the original's List.js pageSize), with a numbered pager.
  const PAGE_SIZE = 9;
  const list = document.querySelector<HTMLElement>('[data-listing]');
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-filter]'));
  const empty = document.querySelector<HTMLElement>('[data-empty]');
  const pager = document.querySelector<HTMLElement>('[data-pager]');

  // A category page is already server-filtered, so its cards can't be filtered
  // further — but they still paginate.
  const isUnfiltered = document.querySelector('[data-filter="*"]')?.getAttribute('aria-current') === 'page';

  if (list) {
    const cards = Array.from(list.querySelectorAll<HTMLElement>('[data-category]'));
    let filter = '*';
    let page = 0;

    const matches = (card: HTMLElement) => filter === '*' || card.dataset.category === filter;

    const render = () => {
      const active = cards.filter(matches);
      const pages = Math.max(1, Math.ceil(active.length / PAGE_SIZE));
      if (page >= pages) page = pages - 1;
      let shownOnPage = 0;
      let idxInActive = 0;
      cards.forEach((card) => {
        if (!matches(card)) { card.hidden = true; return; }
        const onPage = idxInActive >= page * PAGE_SIZE && idxInActive < (page + 1) * PAGE_SIZE;
        card.hidden = !onPage;
        if (onPage) {
          card.style.setProperty('--i', String(shownOnPage));
          card.style.animation = 'none';
          void card.offsetWidth; // reflow so the entrance animation restarts
          card.style.animation = '';
          shownOnPage += 1;
        }
        idxInActive += 1;
      });
      if (empty) empty.hidden = active.length > 0;

      // Rebuild the numbered pager.
      if (pager) {
        pager.replaceChildren();
        pager.classList.toggle('flex', pages > 1);
        pager.classList.toggle('hidden', pages <= 1);
        for (let p = 0; p < pages; p++) {
          const b = document.createElement('button');
          b.type = 'button';
          b.textContent = String(p + 1);
          b.setAttribute('aria-label', `Pagina ${p + 1}`);
          b.className =
            'grid size-10 place-items-center rounded-[10px] border-2 border-mist text-[16px] text-navy transition-colors aria-[current=true]:border-navy aria-[current=true]:bg-navy aria-[current=true]:text-white';
          b.setAttribute('aria-current', String(p === page));
          b.addEventListener('click', () => {
            page = p;
            render();
            list.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
          pager.appendChild(b);
        }
      }
    };

    if (isUnfiltered) {
      links.forEach((link) => {
        link.addEventListener('click', (event) => {
          event.preventDefault();
          filter = link.dataset.filter ?? '*';
          page = 0;
          links.forEach((l) => l.setAttribute('aria-current', l === link ? 'page' : 'false'));
          render();
          history.replaceState(null, '', link.href);
          // Reflect the selected filter in the tab title ("Actueel - Kennis").
          document.title = `Actueel - ${filter === '*' ? 'Alles' : filter}`;
        });
      });
    }

    render();
  }
</script>
