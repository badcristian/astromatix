---
import Button from '../ui/Button.astro';
import Reveal from '../ui/Reveal.astro';
import copy from '../../i18n/home-copy.json';

// Measured @1440:
//   section    y=1505 1440×150, bg navy, padding 40px 24px
//   container  x=151 w=1138 (max-width 1138, centred)
//   heading    751 wide, Poppins 700 28px/35px, white, left-aligned
//   button col 363 wide, 24px gap, button 207×53 vertically centred
interface Props {
  heading?: string;
  cta?: { label: string; href: string };
  /** Anchor id — the homepage hero's "Ontdek de mogelijkheden" scrolls here. */
  id?: string;
}
// Defaults to the homepage strip; other pages pass their own.
const { heading = copy.ctaStrip.heading, cta = copy.ctaStrip.cta, id } = Astro.props;
---

{/* scroll-mt clears the 66px sticky header so the heading isn't hidden under it
    when scrolled to via the hash. */}
<section id={id} class="scroll-mt-[90px] bg-navy px-6 py-10">
  <div class="mx-auto flex max-w-[1138px] flex-col gap-6 md:flex-row md:items-center md:gap-8">
    {/* flex-1 rather than a fixed 751 — a short heading ("Maak deel uit…" on
        over-ons) then fits on one line, while a long one still wraps. */}
    <h2 class="w-full font-display text-[28px] leading-[35px] font-bold text-white md:flex-1">
      {heading}
    </h2>

    <div class="flex items-start md:shrink-0">
      <Reveal variant="zoom" duration={500}>
        <Button href={cta.href} label={cta.label} height={53} icon />
      </Reveal>
    </div>
  </div>
</section>
