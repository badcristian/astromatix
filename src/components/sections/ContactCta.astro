---
import FormStub from '../ui/FormStub.astro';
import copy from '../../i18n/home-copy.json';

// Measured @1440:
//   section  y=4575 1440×894, bg mist, padding 96px 24px
//   h2       650 wide, centred, Poppins 700 30px/33px
//   intro    650 wide, 16px/22.4px
//   form     800 wide, centred
const { contactCta } = copy;
---

<section class="bg-mist px-6 py-24">
  <div class="mx-auto max-w-[800px]">
    <div class="mx-auto max-w-[650px] text-center">
      <h2 class="font-display text-[30px] leading-[33px] font-bold text-navy">
        {contactCta.title}
      </h2>
      {contactCta.intro && (
        <p class="mt-6 text-[16px] leading-[22.4px] text-navy">{contactCta.intro}</p>
      )}
    </div>

    <div class="mt-11">
      <FormStub fields={contactCta.fields} submitLabel={contactCta.submitLabel} />
    </div>
  </div>
</section>
