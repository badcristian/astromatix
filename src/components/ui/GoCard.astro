---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// The original's `.go-card`. Measured @1440:
//   card   363×369, bg #f8f9fb (fog), 24px radius, overflow hidden,
//          margin-bottom 24
//   image  363×272, flush to the card edges
//   body   96 tall, 24px padding
//   text   245 wide — title Poppins 700 20px/28px, desc Manrope 14.4px/20px
//   arrow  20×20, 20px to the left of it
//
// The whole card is a link; the arrow is decorative.

interface Props {
  image: ImageMetadata;
  name: string;
  title: string;
  href: string;
  /**
   * Image aspect. The two pages that use this card genuinely differ on the
   * original: `/nl/klantcases` serves 2:1 (384×192), the homepage "Samen
   * succesvol" section serves 4:3 (363×272) — a taller photo. So it's a prop,
   * not a constant (FINDINGS.md §7).
   */
  aspect?: '2/1' | '4/3';
}

const { image, name, title, href, aspect = '2/1' } = Astro.props;

const aspectClass = aspect === '4/3' ? 'aspect-[4/3]' : 'aspect-[2/1]';
const imgHeight = aspect === '4/3' ? 288 : 192;
---

<a
  href={href}
  class="mb-6 block overflow-hidden rounded-3xl bg-fog transition-opacity hover:opacity-90"
>
  <Image
    src={image}
    alt=""
    width={384}
    height={imgHeight}
    densities={[1, 2]}
    class:list={[aspectClass, 'w-full object-cover']}
  />

  <div class="flex items-center justify-between p-6">
    <div class="w-[245px]">
      <h4 class="font-display text-[20px] leading-[28px] font-bold text-navy">{name}</h4>
      <p class="text-[14.4px] leading-[20px] text-navy">{title}</p>
    </div>

    <span class="ml-5 shrink-0 text-navy" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 12h15m0 0l-5-5m5 5l-5 5" />
      </svg>
    </span>
  </div>
</a>
