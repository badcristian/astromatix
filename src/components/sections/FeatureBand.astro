---
import PropertyItem from '../ui/PropertyItem.astro';
import Reveal from '../ui/Reveal.astro';
import { home } from '../../i18n/nl';

// Measured @1440:
//   band       1440×88, padding 10px 24px
//   background rgba(255,255,255,0.1) over the hero's navy — the original does
//              this with a linear-gradient, we use a plain translucent white
//   items row  x=153 w=1133, centred; items 44px tall at y=647
//   gaps       ~27–28px between items, with a hairline divider
//
// The original overlaps this strip onto the bottom of the hero section. We
// render it as a sibling immediately after, with the hero's bottom padding
// reduced to match — same rendered result, simpler markup.
---

<section class="bg-navy">
  <Reveal variant="up" duration={500} class="bg-white/10 px-6 py-[10px]">
    {/* Inner row is 68px on the original — items are 44px, vertically centred
        with 12px above and below. 10px padding either side makes the strip 88. */}
    <div class="flex h-[68px] flex-wrap items-center justify-center">
      {home.featureBand.map((item, i) => (
        <div
          class:list={[
            // Each item carries ~25px of trailing space on the original,
            // except the last. Without it the whole row measures ~75px narrow.
            i < home.featureBand.length - 1 && 'pr-[25px]',
            i > 0 && 'border-l border-white/20 pl-[14px] ml-[14px]',
          ]}
        >
          <PropertyItem icon={item.icon} label={item.label} variant="light" />
        </div>
      ))}
    </div>
  </Reveal>
</section>
