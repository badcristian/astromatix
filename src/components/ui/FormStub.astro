---
// A visually faithful, deliberately inert form.
//
// The original embeds a HubSpot form that posts into their CRM. This renders
// the same fields and styling but does nothing on submit — it shows a notice
// instead, so demo traffic never pollutes the client's lead data.
//
// Wiring a real backend later is a change to this one file: either drop in
// HubSpot's embed script, or POST to an Astro endpoint that forwards to their
// Forms API.
//
// Measured @1440:
//   form     800 wide
//   input    54 tall, 12px radius, 1px #f5f5ff border, white bg,
//            plus shadow rgba(17,65,122,0.05) 0 8px 16px
//            14.56px padding, 16px text
//   pairs    388 wide each with a 24px gap
//   textarea 800×130
//   submit   117×52, navy, 12px radius

interface Field {
  name: string;
  type: string;
  label: string;
  required: boolean;
  /** For a checkbox/radio: this option's label and the group legend. */
  option?: string | null;
  group?: string | null;
}

interface Props {
  fields: Field[];
  submitLabel: string;
  /**
   * `styled` (default) — the theme's white pill-ish inputs with a soft shadow
   * (contact, product CTAs). `raw` — the plain HubSpot look the funnel pages
   * embed: single column, a 1px grey border, #f5f8fa fill, 3px radius, NO
   * shadow. Measured on /nl/demo-aanvraag: border #959494, bg #f5f8fa, 44px.
   */
  variant?: 'styled' | 'raw';
  /** Submit button colour — navy by default, orange for the newsletter form. */
  submitColor?: 'navy' | 'orange';
  /** Wider form (1200) with paired fields splitting the row — the klantcases. */
  wide?: boolean;
}

const { fields, submitLabel, variant = 'styled', submitColor = 'navy', wide = false } = Astro.props;
const raw = variant === 'raw';
const pairClass = wide ? 'md:flex-1' : 'md:w-[388px]';
const submitBg = submitColor === 'orange' ? 'bg-orange' : 'bg-navy';

// Checkbox/radio groups (jobboost's "Welke boost past bij jou?" — Small /
// Medium / Large) render as ONE labelled set of pill options, not as loose
// inputs. Grouped by field name so a multi-option group collapses to a single
// control. Everything else flows through the normal field layout.
const choiceFields = fields.filter((f) => f.type === 'checkbox' || f.type === 'radio');
const choiceGroups = [...new Set(choiceFields.map((f) => f.name))].map((name) => {
  const items = choiceFields.filter((f) => f.name === name);
  return {
    name,
    legend: items.find((f) => f.group)?.group ?? null,
    type: items[0].type,
    options: items.map((f) => f.option || f.label).filter(Boolean),
  };
});

// Measured on the original: 12px radius plus a soft navy shadow,
// TWO stacked shadows: rgba(17,65,122,0.05) at 0 8px 16px and again at
// 0 4px 8px. We had the radius right and no shadow at all,
// which is why the forms read flatter than the original's.
//
// A first pass set these to 999px pills — that came from probing the FIRST
// <input> on the page, which is a HIDDEN field with different styling. Filter
// to a laid-out element before reading computed style (FINDINGS.md §1).
const fieldChrome = raw
  ? 'border border-[#959494] bg-[#f5f8fa] text-[16px] text-navy outline-none ' +
    'transition-colors focus:border-navy/50'
  : 'border border-mist bg-white text-[16px] text-navy outline-none ' +
    'shadow-[0_8px_16px_0_rgba(17,65,122,0.05),0_4px_8px_0_rgba(17,65,122,0.05)] ' +
    'transition-colors focus:border-navy/30';

const shape = raw ? 'rounded-[3px] p-[10px]' : 'rounded-[12px] p-[14.56px]';
const inputClass = `w-full ${shape} ${fieldChrome}`;
const textareaClass = `w-full ${shape} ${fieldChrome}`;
const inputStyle = raw ? 'height:44px' : 'height:54px';

// The reCAPTCHA response is a hidden textarea the widget fills; not a real
// field, and we do not embed the third-party widget (out of scope, like the
// HubSpot Meetings embeds).
const real = fields.filter((f) => f.name && f.name !== 'g-recaptcha-response');

// The original pairs firstname/lastname and phone/email side by side.
const paired = new Set(['firstname', 'lastname', 'phone', 'email']);
const isChoice = (f: Field) => f.type === 'checkbox' || f.type === 'radio';
const textareas = real.filter((f) => f.type === 'textarea');
// The raw funnel form is a single column — no firstname/lastname pairing.
const singles = real.filter(
  (f) => f.type !== 'textarea' && !isChoice(f) && (raw || !paired.has(f.name)),
);
const pairs = raw ? [] : real.filter((f) => paired.has(f.name));

// Per-field error, shown on submit when a required field is empty — a navy
// pill beneath the field, exactly as the original ("Vul dit verplichte veld
// in."). Rendered for every field; the script reveals only the invalid ones.
const FIELD_ERROR = 'Vul dit verplichte veld in.';
const errorClass =
  'form-error mt-1 hidden w-fit rounded-[6px] bg-navy px-2 py-1 text-[13px] leading-tight text-white';
---

<form class:list={['w-full', raw ? '' : (wide ? 'mx-auto max-w-[1200px]' : 'mx-auto max-w-[800px]')]} data-form-stub novalidate>
  {singles.map((field) => (
    <div class="mb-6">
      <label class="mb-[3px] block text-[16px] text-navy" for={field.name}>{field.label}</label>
      <input
        class={inputClass}
        id={field.name}
        name={field.name}
        type={field.type}
        required={field.required}
        style={inputStyle}
      />
      <span class={errorClass} data-error>{FIELD_ERROR}</span>
    </div>
  ))}

  <div class="mb-6 flex flex-col gap-6 md:flex-row">
    {pairs.slice(0, 2).map((field) => (
      <div class:list={pairClass}>
        <label class="mb-[3px] block text-[16px] text-navy" for={field.name}>{field.label}</label>
        <input class={inputClass} id={field.name} name={field.name} type={field.type} required={field.required} style={inputStyle} />
        <span class={errorClass} data-error>{FIELD_ERROR}</span>
      </div>
    ))}
  </div>

  <div class="mb-6 flex flex-col gap-6 md:flex-row">
    {pairs.slice(2).map((field) => (
      <div class:list={pairClass}>
        <label class="mb-[3px] block text-[16px] text-navy" for={field.name}>{field.label}</label>
        <input class={inputClass} id={field.name} name={field.name} type={field.type} required={field.required} style={inputStyle} />
        <span class={errorClass} data-error>{FIELD_ERROR}</span>
      </div>
    ))}
  </div>

  {choiceGroups.map((group) => (
    <fieldset class="mb-6">
      {group.legend && (
        <legend class="mb-2 block text-[16px] text-navy">{group.legend}</legend>
      )}
      <div class="flex flex-wrap gap-3">
        {group.options.map((option, i) => (
          <label
            class="flex cursor-pointer items-center gap-2 rounded-[12px] border border-mist bg-white px-4 py-3 text-[16px] text-navy shadow-[0_8px_16px_0_rgba(17,65,122,0.05),0_4px_8px_0_rgba(17,65,122,0.05)] transition-colors has-[:checked]:border-navy has-[:checked]:bg-mist"
          >
            <input
              type={group.type}
              name={group.name}
              value={option}
              class="accent-navy"
            />
            {option}
          </label>
        ))}
      </div>
    </fieldset>
  ))}

  {textareas.map((field) => (
    <div class="mb-6">
      <label class="mb-[3px] block text-[16px] text-navy" for={field.name}>{field.label}</label>
      <textarea class={textareaClass} id={field.name} name={field.name} required={field.required} style="height:130px"></textarea>
      <span class={errorClass} data-error>{FIELD_ERROR}</span>
    </div>
  ))}

  {/* Summary error above the submit — "Vul alle verplichte velden in." — shown
      when any required field is empty, exactly as the original. */}
  <p class="mb-4 hidden text-[16px] font-bold text-navy" data-form-summary role="alert">
    Vul alle verplichte velden in.
  </p>

  <button
    type="submit"
    class:list={['inline-flex h-[52px] items-center rounded-[12px] px-[21.76px] text-[16px] font-medium text-white transition-opacity hover:opacity-90', submitBg]}
  >
    {submitLabel}
  </button>

  <p class="mt-4 hidden text-[16px] text-orange" data-form-notice role="status">
    Not fully implemented yet
  </p>
</form>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-form-stub]').forEach((form) => {
    const notice = form.querySelector<HTMLElement>('[data-form-notice]');
    const summary = form.querySelector<HTMLElement>('[data-form-summary]');

    // Show the per-field error beside an input when it is a required field left
    // empty; hide it once filled. Returns whether the field is valid.
    const check = (el: HTMLInputElement | HTMLTextAreaElement) => {
      const ok = !el.required || el.value.trim() !== '';
      const error = el.parentElement?.querySelector('[data-error]');
      error?.classList.toggle('hidden', ok);
      return ok;
    };

    const fields = Array.from(
      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea'),
    );

    // Once a field has been flagged, re-validate it as the user types so the
    // error clears the moment it is fixed.
    fields.forEach((el) =>
      el.addEventListener('input', () => {
        if (!el.parentElement?.querySelector('[data-error]')?.classList.contains('hidden')) check(el);
      }),
    );

    form.addEventListener('submit', (event) => {
      // Deliberately inert: no backend is wired up, and demo submissions must
      // not reach the client's CRM. But the ORIGINAL validates first and only
      // proceeds when the form is complete, so mirror that — show the field and
      // summary errors while anything required is empty, and only surface the
      // "not implemented" notice once everything is valid.
      event.preventDefault();
      const valid = fields.map(check).every(Boolean);
      summary?.classList.toggle('hidden', valid);
      notice?.classList.toggle('hidden', !valid);
    });
  });
</script>
