---
// The original's `.module--steps`. Measured @1440:
//   module   1200 wide, 225 tall
//   nav      1200×51 — four 44×44 circular buttons, ~101px apart, centred
//            active button filled navy, glyph is the step number
//   tooltip  "stap N" sits SNUG above each button (a small caption), not
//            floating high above the row
//   content  1200×174 below the nav
//
// Two bugs fixed here:
//   - the "stap N" label was 41px above the number, reading as detached at the
//     top of the section rather than a caption on its button
//   - panels initialised with `md:hidden` while the JS toggled plain `hidden`,
//     so clicking a number hid the open panel and left the new one hidden —
//     the content area went blank. Visibility now runs off `data-active` plus
//     the scoped rule below, so the button and the JS agree. Tabbed at lg,
//     stacked below it (the original lays all panels out at mobile widths).
//
// Buttons carry aria-selected and the panels are real tabpanels, so this is
// keyboard-navigable — the original uses plain divs.

interface Props {
  steps: {
    label: string | null;
    number: string | null;
    title: string | null;
    body: string | null;
  }[];
}

const { steps } = Astro.props;
const uid = `steps-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="mx-auto max-w-[1200px]" data-steps>
  {/* A thin navy line runs behind the row, connecting the numbers; each
      number's circle sits on top of it. The "stap N" caption is a navy PILL
      shown only above the ACTIVE number (aria-selected drives it) — on the
      original the inactive steps show no pill. */}
  <div class="relative mx-auto flex max-w-[720px] items-start justify-between" role="tablist">
    <div class="absolute top-[calc(1.375rem+28px)] right-[22px] left-[22px] -z-0 h-px bg-navy/20" aria-hidden="true"></div>

    {steps.map((step, i) => (
      <div class="relative z-10 flex flex-col items-center gap-1">
        {step.label && (
          <span
            class="rounded-full px-3 py-1 text-[13.12px] font-medium whitespace-nowrap transition-colors data-[on]:bg-navy data-[on]:text-white"
            data-steps-label={i}
            data-on={i === 0 ? '' : undefined}
            aria-hidden="true"
          >
            {step.label}
          </span>
        )}
        <button
          type="button"
          role="tab"
          id={`${uid}-tab-${i}`}
          aria-controls={`${uid}-panel-${i}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          class="grid size-11 place-items-center rounded-full border border-navy bg-white text-[21.76px] font-medium text-navy transition-colors aria-selected:bg-navy aria-selected:text-white"
          data-steps-tab={i}
        >
          {step.number ?? i + 1}
        </button>
      </div>
    ))}
  </div>

  <div class="mt-8">
    {steps.map((step, i) => (
      <div
        role="tabpanel"
        id={`${uid}-panel-${i}`}
        aria-labelledby={`${uid}-tab-${i}`}
        class="steps-panel mx-auto max-w-[800px] text-center"
        data-steps-panel={i}
        data-active={i === 0 ? '' : undefined}
      >
        {step.title && (
          <h3 class="font-display text-[20px] leading-[28px] font-bold text-navy">
            {step.title}
          </h3>
        )}
        {step.body && step.body !== step.title && (
          <p class="mt-4 text-[16px] leading-[22.4px] text-navy">{step.body}</p>
        )}
      </div>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-steps]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLElement>('[data-steps-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-steps-panel]'));

    const labels = Array.from(root.querySelectorAll<HTMLElement>('[data-steps-label]'));
    const select = (index: number) => {
      tabs.forEach((t, i) => t.setAttribute('aria-selected', String(i === index)));
      labels.forEach((l, i) => {
        if (i === index) l.setAttribute('data-on', '');
        else l.removeAttribute('data-on');
      });
      panels.forEach((p, i) => {
        if (i === index) p.setAttribute('data-active', '');
        else p.removeAttribute('data-active');
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(i));
      tab.addEventListener('keydown', (event) => {
        const key = (event as KeyboardEvent).key;
        if (key !== 'ArrowRight' && key !== 'ArrowLeft') return;
        event.preventDefault();
        const next = (i + (key === 'ArrowRight' ? 1 : -1) + tabs.length) % tabs.length;
        tabs[next].focus();
        select(next);
      });
    });
  });
</script>

<style>
  /* Tabbed at lg, stacked below it. Same pattern as FeatureShowcase. */
  @media (min-width: 1140px) {
    .steps-panel { display: none; }
    .steps-panel[data-active] { display: block; }
  }
</style>
