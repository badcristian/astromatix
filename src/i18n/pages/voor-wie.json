  "audienceBlocks": [
    {
      "title": "Maximaal resultaat met minimale tijdsinvestering",
      "body": "Je hebt geen fulltime recruitment-afdeling, maar je hebt wél die ene cruciale nieuwe collega nodig. Jobmatix fungeert als jouw 'digitale recruiter'. Wij nemen het complexe werk van jobboards, biedingen en teksten schrijven uit handen. Zo concurreer je moeiteloos met de grote spelers op de arbeidsmarkt, terwijl jij je gewoon op je bedrijfsvoering kunt storten.",
      "image": "https://www.jobmatix.com/hs-fs/hubfs/Doelgroepen1.jpg",
      "imageRight": false,
      "properties": [
        {
          "label": "Gebruiksgemak"
        },
