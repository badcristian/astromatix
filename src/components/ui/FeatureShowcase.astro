---
// The original's `.featshow` (nav-left variant). Measured @1440 on
// /nl/oplossingen/jobadvertising:
//   wrapper  1200 wide, 514 tall
//   nav      480 wide on the left, inner list 370 wide
//   content  720 wide, white, 24px radius
//   panel    inner wrapper 500 wide
//
// A nav entry on the LEFT swaps the panel on the RIGHT, and pagination dots
// under the panel do the same. Built as buttons with aria-selected so it is
// keyboard-navigable.
//
// RESPONSIVE: tabbed at every width (the original tabs on mobile too — its
// panels all sit at one y). The nav labels stack above the card on mobile and
// act as the tabs. The previous version hid
// non-first panels with `md:hidden` while the JS toggled plain `hidden` — the
// two never corresponded, so clicking a tab hid the open panel and left the
// new one still hidden, i.e. the box went blank. The visibility is now driven
// entirely by a `data-active` attribute plus the scoped rule below, so the
// tab, the dots, and the JS all agree.

interface Props {
  items: { title: string; body: string | null }[];
}

const { items } = Astro.props;
const uid = `featshow-${Math.random().toString(36).slice(2, 8)}`;
---

{/* nav 480 + card 720 = the 1200 row exactly, so lg:gap-0 (the original has
    no gap between them; the nav's own 480→370 inset is the visual gutter). */}
<div class="mx-auto flex max-w-[1200px] flex-col gap-8 lg:flex-row lg:gap-0" data-featshow>
  {/* The nav column stretches to the card's height (flex-row default); center
      the labels within it, matching the original (nav centre = card centre). */}
  <div class="lg:flex lg:w-[480px] lg:shrink-0 lg:flex-col lg:justify-center">
    <ul class="mx-auto flex max-w-[370px] flex-col gap-4" role="tablist">
      {items.map((item, i) => (
        <li>
          <button
            type="button"
            role="tab"
            id={`${uid}-tab-${i}`}
            aria-controls={`${uid}-panel-${i}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            class="w-full text-left font-display text-[22px] leading-[28px] font-bold text-navy lg:text-[28px] lg:leading-[35px]"
            data-featshow-tab={i}
          >
            {item.title}
          </button>
        </li>
      ))}
    </ul>
  </div>

  {/* The right panel is a white card with the theme's soft navy shadow
      (measured on .featshow__content, 720x514). The nav labels on the left sit
      on the mist section background, not inside this card. min-h holds the box
      at the original's height regardless of which panel is open; content is
      centred vertically and the dots + arrows pin to the bottom. */}
  <div class="lg:w-[720px] lg:shrink-0">
    <div class="flex flex-col rounded-3xl bg-white p-10 shadow-card-lg lg:min-h-[514px]">
      <div class="flex flex-1 flex-col justify-center">
        {items.map((item, i) => (
          <div
            role="tabpanel"
            id={`${uid}-panel-${i}`}
            aria-labelledby={`${uid}-tab-${i}`}
            class="fs-panel mx-auto w-full max-w-[500px]"
            data-featshow-panel={i}
            data-active={i === 0 ? '' : undefined}
          >
            <h3 class="font-display text-[28px] leading-[34px] font-bold text-[#5478f7] lg:text-[40px] lg:leading-[44px]">
              {item.title}
            </h3>
            {item.body && (
              <p class="mt-4 text-[16px] leading-[22.4px] text-navy">{item.body}</p>
            )}
          </div>
        ))}
      </div>

      {/* Dots (left) + prev/next arrows (right), inside the card at the bottom
          — matching the original. Hidden below lg, where the nav labels
          double as the tabs. */}
      <div class="mt-8 hidden items-center justify-between lg:flex">
        <div class="flex gap-3" role="tablist" aria-label="Selecteer">
          {items.map((_, i) => (
            <button
              type="button"
              aria-label={`Toon ${i + 1}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              class="size-3 rounded-full bg-navy/20 transition-colors aria-selected:bg-navy"
              data-featshow-dot={i}
            />
          ))}
        </div>
        <div class="flex items-center gap-5 text-navy">
          <button
            type="button"
            aria-label="Vorige"
            class="transition-opacity disabled:opacity-30"
            disabled
            data-featshow-prev
          >
            <svg width="26" height="18" viewBox="0 0 26 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="25" y1="9" x2="2" y2="9" /><polyline points="9 2 2 9 9 16" />
            </svg>
          </button>
          <button
            type="button"
            aria-label="Volgende"
            class="transition-opacity disabled:opacity-30"
            data-featshow-next
          >
            <svg width="26" height="18" viewBox="0 0 26 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="1" y1="9" x2="24" y2="9" /><polyline points="17 2 24 9 17 16" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Only the active panel shows — tabbed at EVERY width, matching the original
     (its featshow panels all sit at the same y on mobile, i.e. one at a time).
     The nav labels on the left are the tabs. */
  .fs-panel { display: none; }
  .fs-panel[data-active] { display: block; }

  /* The original animates the content when you switch entries. A panel goes
     display:none → block on activation, which restarts this fade + slight rise
     each time. Opt out under reduced-motion. */
  @media (prefers-reduced-motion: no-preference) {
    .fs-panel[data-active] {
      animation: fs-panel-in 0.35s cubic-bezier(0.22, 0.61, 0.36, 1) both;
    }
  }
  @keyframes fs-panel-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }
</style>

<script>
  import { autoplay } from '../../lib/carousel';

  document.querySelectorAll<HTMLElement>('[data-featshow]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLElement>('[data-featshow-tab]'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-featshow-dot]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-featshow-panel]'));
    const prev = root.querySelector<HTMLButtonElement>('[data-featshow-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-featshow-next]');

    let current = 0;
    const select = (index: number) => {
      current = index;
      tabs.forEach((t, i) => t.setAttribute('aria-selected', String(i === index)));
      dots.forEach((d, i) => d.setAttribute('aria-selected', String(i === index)));
      panels.forEach((p, i) => {
        if (i === index) p.setAttribute('data-active', '');
        else p.removeAttribute('data-active');
      });
      // The original disables an arrow at each end rather than wrapping.
      if (prev) prev.disabled = index === 0;
      if (next) next.disabled = index === tabs.length - 1;
    };

    // Autoplay wraps past the last tab (the arrows don't, but a self-running
    // carousel that stalls at the end would just stop).
    const player = autoplay(root, () => select((current + 1) % tabs.length));

    prev?.addEventListener('click', () => { if (current > 0) select(current - 1); player.reset(); });
    next?.addEventListener('click', () => { if (current < tabs.length - 1) select(current + 1); player.reset(); });

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => { select(i); player.reset(); });
      tab.addEventListener('keydown', (event) => {
        const key = (event as KeyboardEvent).key;
        if (key !== 'ArrowRight' && key !== 'ArrowLeft') return;
        event.preventDefault();
        const nextIndex = (i + (key === 'ArrowRight' ? 1 : -1) + tabs.length) % tabs.length;
        tabs[nextIndex].focus();
        select(nextIndex);
        player.reset();
      });
    });

    dots.forEach((dot, i) => dot.addEventListener('click', () => { select(i); player.reset(); }));
  });
</script>
